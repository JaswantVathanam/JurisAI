<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.AI.Projects" Version="1.2.0-beta.4" />
    <PackageReference Include="Azure.Identity" Version="1.17.1" />
    <PackageReference Include="Azure.Identity.Broker" Version="1.3.1" />
    <PackageReference Include="Azure.Maps.Search" Version="2.0.0-beta.4" />
    <PackageReference Include="QuestPDF" Version="2024.12.2" />
  </ItemGroup>

  <!-- Auto-sign DLL after build (required for Smart App Control) -->
  <Target Name="SignAssembly" AfterTargets="Build">
    <Exec Command="powershell -NoProfile -Command &quot;$cert = Get-ChildItem Cert:\CurrentUser\My\484DFA53DCF8EEDDD02B5ED7570B8E83D016C895 -ErrorAction SilentlyContinue; if ($cert) { Set-AuthenticodeSignature -FilePath '$(TargetPath)' -Certificate $cert -HashAlgorithm SHA256 | Out-Null; Write-Host 'Signed: $(TargetFileName)' } else { Write-Warning 'Code signing cert not found - DLL unsigned' }&quot;" />
  </Target>

</Project>
