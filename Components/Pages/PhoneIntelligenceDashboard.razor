        }
    }
    
    private async Task PlotNetworkLocations()
    {
        if (networkMapViewer == null || networkGraph == null) return;

        try
        {
            await networkMapViewer.ClearMarkersAsync();
            LocationData? firstLocation = null;

            foreach (var node in networkGraph.Nodes.Where(n => !string.IsNullOrEmpty(n.Location)))
            {
                var loc = await MapsService.GeocodeAddressAsync(node.Location!);
                if (loc != null)
                {
                    var color = node.IsLeader ? "#ff1744" :
                                node.RiskLevel == "Critical" ? "#ff6b6b" :
                                node.RiskLevel == "High" ? "#ff9800" :
                                node.NodeType == "victim" ? "#4caf50" : "#00d4ff";

                    var title = $"{node.SuspectName ?? "Unknown"} ({node.PhoneNumber?.Substring(Math.Max(0, (node.PhoneNumber?.Length ?? 0) - 4))}) — {node.Role}";
                    await networkMapViewer.AddMarkerAsync(loc, title, color);

                    firstLocation ??= loc;
                }
            }

            if (firstLocation != null)
            {
                await networkMapViewer.CenterMapAsync(firstLocation.Latitude, firstLocation.Longitude, 11);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Map error: {ex.Message}");
        }
    }

    private async Task FocusOnSuspect(NetworkNode node)
    {
        selectedNode = node;
        if (networkMapViewer == null || string.IsNullOrEmpty(node.Location)) return;

        try
        {
            var loc = await MapsService.GeocodeAddressAsync(node.Location);
            if (loc != null)
            {
                await networkMapViewer.CenterMapAsync(loc.Latitude, loc.Longitude, 15);
            }
        }
        catch { }
    }

    // Helper methods
    private string GetProvider(string phone)
    {
        if (string.IsNullOrEmpty(phone) || phone.Length < 4) return "Unknown";
        var prefix = phone.Substring(0, 4);
        return prefix switch
        {
            "9876" or "9877" or "9878" => "Airtel",
            "9999" or "9998" or "9997" => "Jio",
            "9876" or "9871" or "9872" => "Vodafone",
            _ => "Unknown Provider"
        };
    }
    
    private string GetRiskClass(string? riskLevel)
    {
        return riskLevel?.ToLower() switch
        {
            "critical" => "risk-critical",
            "high" => "risk-high",
            "medium" => "risk-medium",
            "low" => "risk-low",
            _ => ""
        };
    }
    
    private string GetRoleClass(string? role)
    {
        return role?.ToLower() switch
        {
            "leader" => "role-leader",
            "money handler" => "role-money",
            "caller" => "role-caller",
            "recruiter" => "role-recruiter",
            _ => "role-associate"
        };
    }
    
    private string GetNodeClass(NetworkNode node)
    {
        var classes = new List<string>();
        
        if (node.IsLeader) classes.Add("leader");
        else if (node.NodeType == "victim") classes.Add("victim");
        else if (node.NodeType == "suspect") classes.Add("suspect");
        else classes.Add("unknown");
        
        if (node.RiskLevel == "High" || node.RiskLevel == "Critical")
            classes.Add("high-risk");
            
        return string.Join(" ", classes);
    }
    
    private string GetEdgeClass(NetworkEdge edge)
    {
        if (edge.MoneyTransferred > 50000) return "money-flow";
        if (edge.CallCount > 50) return "frequent";
        return "normal";
    }
    
    private int GetNodeRadius(NetworkNode node)
    {
        var baseRadius = 15;
        if (node.IsLeader) return baseRadius + 10;
        if (node.CentralityScore > 70) return baseRadius + 5;
        return baseRadius;
    }
    
    private (int x, int y) GetNodePosition(NetworkNode node, List<NetworkNode> allNodes)
    {
        // Center of the 800x500 viewBox
        int cx = 400, cy = 250;

        // Root node at center
        if (node.PhoneNumber == networkGraph?.RootPhoneNumber)
            return (cx, cy);

        // Separate nodes into rings by role/risk
        var others = allNodes.Where(n => n.PhoneNumber != networkGraph?.RootPhoneNumber).ToList();

        int ring;
        double radius;
        if (node.IsLeader)
        {
            ring = 0; radius = 100;
        }
        else if (node.RiskLevel == "Critical" || node.RiskLevel == "High")
        {
            ring = 1; radius = 180;
        }
        else
        {
            ring = 2; radius = 230;
        }

        // Nodes in the same ring
        var sameRing = others.Where(n =>
            ring == 0 ? n.IsLeader :
            ring == 1 ? (!n.IsLeader && (n.RiskLevel == "Critical" || n.RiskLevel == "High")) :
            (!n.IsLeader && n.RiskLevel != "Critical" && n.RiskLevel != "High")).ToList();

        var ringIdx = sameRing.IndexOf(node);
        var ringCount = Math.Max(sameRing.Count, 1);

        // Offset each ring so nodes don't line up
        var angleOffset = ring * Math.PI / 5.0;
        var angle = angleOffset + (2 * Math.PI * ringIdx) / ringCount;

        var x = Math.Clamp((int)(cx + radius * Math.Cos(angle)), 35, 765);
        var y = Math.Clamp((int)(cy + radius * Math.Sin(angle)), 35, 465);

        return (x, y);
    }
    
    private string ConvertMarkdown(string markdown)
    {
        if (string.IsNullOrEmpty(markdown)) return "";
        
        // Simple markdown conversion
        var html = markdown
            .Replace("## ", "<h4>").Replace("\n\n", "</h4>\n")
            .Replace("### ", "<h5>").Replace("**", "<strong>").Replace("**", "</strong>")
            .Replace("- ", "<li>").Replace("\n", "<br/>");
            
        return html;
    }
