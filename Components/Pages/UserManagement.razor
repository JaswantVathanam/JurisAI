    {
        var csv = new System.Text.StringBuilder();
        
        // Header
        csv.AppendLine("ID,Name,Email,Phone,Role,Verification Status,Account Status,Joined Date");
        
        // Data rows
        foreach (var user in users)
        {
            csv.AppendLine($"{user.Id}," +
                          $"\"{user.Name}\"," +
                          $"\"{user.Email}\"," +
                          $"\"{user.Phone ?? "N/A"}\"," +
                          $"{user.Role}," +
                          $"{user.VerificationStatus}," +
                          $"{(user.IsActive ? "Active" : "Inactive")}," +
                          $"{user.CreatedAt:yyyy-MM-dd}");
