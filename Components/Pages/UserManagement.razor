    protected override async Task OnInitializedAsync()
    {
        currentUser = AuthService.GetCurrentUser();
        
        if (currentUser?.Role != UserRole.Admin)
        {
            return;
        }

        await LoadUsersAsync();
        await CalculateStatisticsAsync();
    }

    private async Task LoadUsersAsync()
    {
        isLoadingUsers = true;
        StateHasChanged();
        
        try
        {
            // Simulate network delay for demonstration
            await Task.Delay(800);
            
            allUsers = AuthService.GetAllUsers()
                .Where(u => u.Role != UserRole.Admin) // Don't show admin users
                .ToList();
        }
        catch (Exception ex)
        {
            ShowSuccess($"Error loading users: {ex.Message}");
            Console.WriteLine($"Error in LoadUsersAsync: {ex}");
        }
        finally
        {
            isLoadingUsers = false;
            StateHasChanged();
        }
    }

    private async Task CalculateStatisticsAsync()
    {
        isLoadingStats = true;
        StateHasChanged();
        
        try
        {
            // Simulate processing delay
            await Task.Delay(600);
            
            citizenCount = allUsers.Count(u => u.Role == UserRole.Citizen);
            lawyerCount = allUsers.Count(u => u.Role == UserRole.Lawyer);
            policeCount = allUsers.Count(u => u.Role == UserRole.Police);
            totalUsers = allUsers.Count;
        }
        catch (Exception ex)
        {
            ShowSuccess($"Error calculating statistics: {ex.Message}");
            Console.WriteLine($"Error in CalculateStatisticsAsync: {ex}");
        }
        finally
        {
            isLoadingStats = false;
            StateHasChanged();
        }
    }

    private List<User> GetFilteredUsers()
    {
        var filtered = allUsers.AsEnumerable();

        // Filter by role
        if (filterRole != "All")
        {
            var role = Enum.Parse<UserRole>(filterRole);
            filtered = filtered.Where(u => u.Role == role);
        }

        // Filter by verification status
        if (filterStatus != "All")
        {
            var status = Enum.Parse<VerificationStatus>(filterStatus);
            filtered = filtered.Where(u => u.VerificationStatus == status);
        }

        // Filter by active status
        if (filterActive == "Active")
        {
            filtered = filtered.Where(u => u.IsActive);
        }
        else if (filterActive == "Inactive")
        {
            filtered = filtered.Where(u => !u.IsActive);
        }

        // Filter by date range
        if (filterDateFrom.HasValue)
        {
            filtered = filtered.Where(u => u.CreatedAt.Date >= filterDateFrom.Value.Date);
        }
        if (filterDateTo.HasValue)
        {
            filtered = filtered.Where(u => u.CreatedAt.Date <= filterDateTo.Value.Date);
        }

        // Search filter
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var query = searchQuery.ToLower();
            filtered = filtered.Where(u => 
                u.Name.ToLower().Contains(query) ||
                u.Email.ToLower().Contains(query) ||
                (u.Phone?.ToLower().Contains(query) ?? false) ||
                u.Id.ToString().Contains(query)
            );
        }

        // Apply sorting
        filtered = sortColumn switch
        {
            "Name" => sortAscending ? filtered.OrderBy(u => u.Name) : filtered.OrderByDescending(u => u.Name),
            "Email" => sortAscending ? filtered.OrderBy(u => u.Email) : filtered.OrderByDescending(u => u.Email),
            "Role" => sortAscending ? filtered.OrderBy(u => u.Role) : filtered.OrderByDescending(u => u.Role),
            "VerificationStatus" => sortAscending ? filtered.OrderBy(u => u.VerificationStatus) : filtered.OrderByDescending(u => u.VerificationStatus),
            "IsActive" => sortAscending ? filtered.OrderBy(u => u.IsActive) : filtered.OrderByDescending(u => u.IsActive),
            "CreatedAt" => sortAscending ? filtered.OrderBy(u => u.CreatedAt) : filtered.OrderByDescending(u => u.CreatedAt),
            _ => filtered.OrderByDescending(u => u.CreatedAt)
        };

        return filtered.ToList();
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            // Toggle sort direction if clicking the same column
            sortAscending = !sortAscending;
        }
        else
        {
            // New column, default to ascending
            sortColumn = column;
            sortAscending = true;
        }
    }

    private void ClearFilters()
    {
        filterRole = "All";
        filterStatus = "All";
        filterActive = "All";
        filterDateFrom = null;
        filterDateTo = null;
        searchQuery = string.Empty;
        ShowSuccess("Filters cleared!");
