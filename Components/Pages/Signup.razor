@page "/signup"
@using AILegalAsst.Models
@using AILegalAsst.Services
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Sign Up - JurisAI</PageTitle>

<div class="signup-page">
    <div class="signup-container">
        <div class="signup-header">
            <div class="logo">
                <i class="bi bi-shield-check"></i>
            </div>
            <h1>Create Your Account</h1>
            <p>Join India's AI-powered legal assistance platform</p>
        </div>

        @if (!roleSelected)
        {
            <!-- Role Selection -->
            <div class="role-selection">
                <h2>I am signing up as:</h2>
                <div class="role-cards">
                    <div class="role-card" @onclick="() => SelectRole(UserRole.Citizen)">
                        <div class="role-icon citizen">
                            <i class="bi bi-person-circle"></i>
                        </div>
                        <h3>Citizen</h3>
                        <p>Quick signup for legal help</p>
                        <ul>
                            <li>File complaints</li>
                            <li>Track cases</li>
                            <li>Get legal advice</li>
                        </ul>
                        <span class="badge-quick">Instant Access</span>
                    </div>

                    <div class="role-card" @onclick="() => SelectRole(UserRole.Lawyer)">
                        <div class="role-icon lawyer">
                            <i class="bi bi-briefcase"></i>
                        </div>
                        <h3>Lawyer</h3>
                        <p>Professional account</p>
                        <ul>
                            <li>Manage cases</li>
                            <li>Connect with clients</li>
                            <li>Legal research</li>
                        </ul>
                        <span class="badge-verify">Verification Required</span>
                    </div>

                    <div class="role-card" @onclick="() => SelectRole(UserRole.Police)">
                        <div class="role-icon police">
                            <i class="bi bi-shield-fill-exclamation"></i>
                        </div>
                        <h3>Police Officer</h3>
                        <p>Government access</p>
                        <ul>
                            <li>Manage investigations</li>
                            <li>Track cybercrimes</li>
                            <li>Case coordination</li>
                        </ul>
                        <span class="badge-verify">Strict Verification</span>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Back Button -->
            <button class="btn-back" @onclick="() => roleSelected = false">
                <i class="bi bi-arrow-left"></i> Change Role
            </button>

            <!-- Signup Form -->
            <div class="signup-form">
                <div class="form-header">
                    <div class="role-badge @selectedRole.ToString().ToLower()">
                        <i class="bi @GetRoleIcon()"></i>
                        @selectedRole Signup
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-error">
                        <i class="bi bi-exclamation-triangle"></i>
                        @errorMessage
                    </div>
                }

                <!-- Common Fields -->
                <div class="form-section">
                    <h3>Personal Information</h3>
                    
                    <div class="form-group">
                        <label>Full Name *</label>
                        <input type="text" @bind="signupModel.Name" placeholder="Enter your full name" />
                    </div>

                    <div class="form-group">
                        <label>Email Address *</label>
                        <input type="email" @bind="signupModel.Email" placeholder="your.email@example.com" />
                        @if (selectedRole == UserRole.Police)
                        {
                            <small class="hint">Must be official government email</small>
                        }
                    </div>

                    <div class="form-group">
                        <label>Phone Number *</label>
                        <input type="tel" @bind="signupModel.Phone" placeholder="+91 XXXXX XXXXX" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Password *</label>
                            <input type="password" @bind="signupModel.Password" placeholder="Min. 8 characters" />
                        </div>
                        <div class="form-group">
                            <label>Confirm Password *</label>
                            <input type="password" @bind="confirmPassword" placeholder="Re-enter password" />
                        </div>
                    </div>
                </div>

                <!-- Citizen-specific Fields -->
                @if (selectedRole == UserRole.Citizen)
                {
                    <div class="form-section">
                        <h3>Additional Details (Optional)</h3>
                        
                        <div class="form-group">
                            <label>Address</label>
                            <textarea @bind="signupModel.Address" rows="3" placeholder="Your residential address"></textarea>
                        </div>

                        <div class="form-group">
                            <label>Aadhaar Number (Optional - for advanced features)</label>
                            <input type="text" @bind="signupModel.AadhaarNumber" placeholder="XXXX-XXXX-XXXX" />
                            <small class="hint">Will be encrypted and stored securely</small>
                        </div>
                    </div>
                }

                <!-- Lawyer-specific Fields -->
                @if (selectedRole == UserRole.Lawyer)
                {
                    <div class="form-section">
                        <h3>Professional Details</h3>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label>Bar Council Registration Number *</label>
                                <input type="text" @bind="signupModel.BarCouncilNumber" placeholder="e.g., MH/2015/12345" />
                            </div>
                            <div class="form-group">
                                <label>State Bar Council *</label>
                                <select @bind="signupModel.BarCouncilState">
                                    <option value="">Select State</option>
                                    <option value="Maharashtra">Maharashtra</option>
                                    <option value="Delhi">Delhi</option>
                                    <option value="Karnataka">Karnataka</option>
                                    <option value="Tamil Nadu">Tamil Nadu</option>
                                    <option value="Gujarat">Gujarat</option>
                                    <option value="Rajasthan">Rajasthan</option>
                                    <option value="Uttar Pradesh">Uttar Pradesh</option>
                                    <!-- Add more states -->
                                </select>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Years of Practice *</label>
                                <input type="number" @bind="signupModel.YearsOfPractice" min="0" placeholder="e.g., 5" />
                            </div>
                            <div class="form-group">
                                <label>Specialization *</label>
                                <input type="text" @bind="signupModel.Specialization" placeholder="e.g., Criminal, Cyber" />
                                <small class="hint">Separate multiple with commas</small>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Office Address *</label>
                            <textarea @bind="signupModel.OfficeAddress" rows="2" placeholder="Your office address"></textarea>
                        </div>

                        <div class="form-group">
                            <label>Bar Council Certificate * (PDF/Image)</label>
                            <div class="file-upload">
                                <input type="file" id="barCouncilCert" accept=".pdf,.jpg,.jpeg,.png" />
                                <label for="barCouncilCert">
                                    <i class="bi bi-upload"></i> Upload Certificate
                                </label>
                            </div>
                        </div>
                    </div>
                }

                <!-- Police-specific Fields -->
                @if (selectedRole == UserRole.Police)
                {
                    <div class="form-section">
                        <h3>Service Details</h3>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label>Police ID / Service Number *</label>
                                <input type="text" @bind="signupModel.PoliceId" placeholder="e.g., DL/2018/5678" />
                            </div>
                            <div class="form-group">
                                <label>Rank *</label>
                                <select @bind="signupModel.Rank">
                                    <option value="">Select Rank</option>
                                    <option value="Constable">Constable</option>
                                    <option value="Head Constable">Head Constable</option>
                                    <option value="Sub-Inspector">Sub-Inspector</option>
                                    <option value="Inspector">Inspector</option>
                                    <option value="Deputy SP">Deputy SP</option>
                                    <option value="SP">SP</option>
                                    <option value="DIG">DIG</option>
                                    <option value="IG">IG</option>
                                    <option value="DGP">DGP</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Department *</label>
                                <select @bind="signupModel.Department">
                                    <option value="">Select Department</option>
                                    <option value="Cyber Crime">Cyber Crime</option>
                                    <option value="Criminal Investigation">Criminal Investigation</option>
                                    <option value="Traffic">Traffic</option>
                                    <option value="Law & Order">Law & Order</option>
                                    <option value="Special Branch">Special Branch</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Police Station *</label>
                                <input type="text" @bind="signupModel.PoliceStation" placeholder="e.g., Connaught Place PS" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Jurisdiction *</label>
                            <input type="text" @bind="signupModel.Jurisdiction" placeholder="e.g., Central Delhi" />
                        </div>

                        <div class="form-group">
                            <label>Service ID Card * (Both Sides - PDF/Image)</label>
                            <div class="file-upload">
                                <input type="file" id="serviceIdCard" accept=".pdf,.jpg,.jpeg,.png" />
                                <label for="serviceIdCard">
                                    <i class="bi bi-upload"></i> Upload ID Card
                                </label>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Departmental Authorization Letter *</label>
                            <div class="file-upload">
                                <input type="file" id="authLetter" accept=".pdf,.jpg,.jpeg,.png" />
                                <label for="authLetter">
                                    <i class="bi bi-upload"></i> Upload Authorization
                                </label>
                            </div>
                        </div>
                    </div>
                }

                <!-- Terms & Submit -->
                <div class="form-section">
                    <div class="form-checkbox">
                        <input type="checkbox" id="terms" @bind="acceptTerms" />
                        <label for="terms">
                            I agree to the <a href="/terms">Terms & Conditions</a> and <a href="/privacy">Privacy Policy</a>
                        </label>
                    </div>

                    @if (selectedRole != UserRole.Citizen)
                    {
                        <div class="verification-notice">
                            <i class="bi bi-info-circle"></i>
                            <div>
                                <strong>Verification Required:</strong>
                                Your account will be reviewed by our team within 
                                @(selectedRole == UserRole.Lawyer ? "24-48 hours" : "48-72 hours").
                                You'll receive an email notification once verified.
                            </div>
                        </div>
                    }

                    <button class="btn-submit" @onclick="HandleSignup" disabled="@(!acceptTerms || isSubmitting)">
                        @if (isSubmitting)
                        {
                            <span class="spinner"></span>
                            <span>Creating Account...</span>
                        }
                        else
                        {
                            <span>Create Account</span>
                        }
                    </button>

                    <div class="form-footer">
                        Already have an account? <a href="/login">Login here</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool roleSelected = false;
    private UserRole selectedRole = UserRole.Citizen;
    private User signupModel = new();
    private string confirmPassword = string.Empty;
    private bool acceptTerms = false;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    private void SelectRole(UserRole role)
    {
        selectedRole = role;
        signupModel = new User { Role = role };
        roleSelected = true;
    }

    private string GetRoleIcon()
    {
        return selectedRole switch
        {
            UserRole.Citizen => "bi-person-circle",
            UserRole.Lawyer => "bi-briefcase",
            UserRole.Police => "bi-shield-fill-exclamation",
            _ => "bi-person"
        };
    }

    private async Task HandleSignup()
    {
        errorMessage = string.Empty;
        
        // Validation
        if (string.IsNullOrWhiteSpace(signupModel.Name) || 
            string.IsNullOrWhiteSpace(signupModel.Email) || 
            string.IsNullOrWhiteSpace(signupModel.Phone) ||
            string.IsNullOrWhiteSpace(signupModel.Password))
        {
            errorMessage = "Please fill all required fields.";
            return;
        }

        if (signupModel.Password != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        if (signupModel.Password.Length < 8)
        {
            errorMessage = "Password must be at least 8 characters.";
            return;
        }

        // Role-specific validation
        if (selectedRole == UserRole.Lawyer)
        {
            if (string.IsNullOrWhiteSpace(signupModel.BarCouncilNumber) ||
                string.IsNullOrWhiteSpace(signupModel.BarCouncilState) ||
                !signupModel.YearsOfPractice.HasValue)
            {
                errorMessage = "Please complete all professional details.";
                return;
            }
        }

        if (selectedRole == UserRole.Police)
        {
            if (string.IsNullOrWhiteSpace(signupModel.PoliceId) ||
                string.IsNullOrWhiteSpace(signupModel.Rank) ||
                string.IsNullOrWhiteSpace(signupModel.Department))
            {
                errorMessage = "Please complete all service details.";
                return;
            }

            if (!signupModel.Email.Contains("police.gov.in") && 
                !signupModel.Email.Contains("gov.in"))
            {
                errorMessage = "Police officers must use official government email.";
                return;
            }
        }

        isSubmitting = true;
        try
        {
            // Simulate async operation
            await Task.Delay(100);

            // Set verification status based on role
            if (selectedRole == UserRole.Citizen)
            {
                signupModel.VerificationStatus = VerificationStatus.Verified; // Auto-verify citizens
            }
            else
            {
                signupModel.VerificationStatus = VerificationStatus.Pending; // Require verification
            }

            // Register user
            var user = AuthService.Register(signupModel);
            
            if (user != null)
            {
                // TODO: Send verification email
                
                if (selectedRole == UserRole.Citizen)
                {
                    // Auto-login for citizens
                    Navigation.NavigateTo("/");
                }
                else
                {
                    // Show verification pending message
                    Navigation.NavigateTo("/verification-pending");
                }
            }
            else
            {
                errorMessage = "Email already exists. Please use a different email.";
            }
        }
        catch
        {
            errorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
