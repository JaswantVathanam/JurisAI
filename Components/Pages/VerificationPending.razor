@page "/verification-pending"
@using AILegalAsst.Services
@inject AuthenticationService AuthService
@inject NavigationManager Navigation

<PageTitle>Verification Pending - JurisAI</PageTitle>

<div class="verification-pending-v2">
    <div class="verification-container-v2">
        <div class="verification-icon-v2">
            <i class="bi bi-hourglass-split"></i>
        </div>
        
        <h1 class="page-title-v2">Account Under Verification</h1>
        <p class="page-subtitle-v2">Thank you for registering with JurisAI!</p>

        <div class="status-card-v2">
            <div class="status-header-v2">
                <i class="bi bi-info-circle"></i>
                <h3>What happens next?</h3>
            </div>
            
            <div class="timeline-v2">
                <div class="timeline-item-v2">
                    <div class="timeline-marker-v2 done">
                        <i class="bi bi-check"></i>
                    </div>
                    <div class="timeline-content-v2">
                        <h4>Registration Complete</h4>
                        <p>Your application has been submitted successfully</p>
                    </div>
                </div>

                <div class="timeline-item-v2">
                    <div class="timeline-marker-v2 active">
                        <i class="bi bi-clock"></i>
                    </div>
                    <div class="timeline-content-v2">
                        <h4>Document Verification</h4>
                        <p>Our team is reviewing your credentials</p>
                    </div>
                </div>

                <div class="timeline-item-v2">
                    <div class="timeline-marker-v2">
                        <i class="bi bi-envelope"></i>
                    </div>
                    <div class="timeline-content-v2">
                        <h4>Email Notification</h4>
                        <p>You'll receive confirmation once approved</p>
                    </div>
                </div>

                <div class="timeline-item-v2">
                    <div class="timeline-marker-v2">
                        <i class="bi bi-unlock"></i>
                    </div>
                    <div class="timeline-content-v2">
                        <h4>Account Activation</h4>
                        <p>Full access to all features</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="info-cards-v2">
            <div class="info-card-v2">
                <div class="info-card-icon-v2">
                    <i class="bi bi-clock-history"></i>
                </div>
                <h4>Verification Time</h4>
                <p>Typically 24-72 hours</p>
            </div>

            <div class="info-card-v2">
                <div class="info-card-icon-v2">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h4>Security First</h4>
                <p>Ensuring platform integrity</p>
            </div>

            <div class="info-card-v2">
                <div class="info-card-icon-v2">
                    <i class="bi bi-headset"></i>
                </div>
                <h4>Need Help?</h4>
                <p>Contact support@ailegal.in</p>
            </div>
        </div>

        <div class="actions-v2">
            <button class="btn-action-v2" @onclick="GoToLogin">
                <i class="bi bi-box-arrow-in-right"></i> Go to Login
            </button>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        var user = AuthService.GetCurrentUser();
        if (user == null)
        {
            Navigation.NavigateTo("/login");
        }
        else if (user.IsVerified)
        {
            Navigation.NavigateTo("/");
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }
}
