    private async Task<string> HandleSuspectNetworkAsync(string query)
    {
        var phoneMatch = System.Text.RegularExpressions.Regex.Match(query, @"\b(\+?\d{10,13})\b");
        if (!phoneMatch.Success)
        {
            pendingFollowUpIntent = SpecializedIntent.SuspectNetwork;
            return "Please provide a phone number or suspect identifier for network analysis.";
        }

        var phone = phoneMatch.Value;
        var result = await SuspectNetSvc.BuildNetworkGraphAsync(phone);

        var context = new System.Text.StringBuilder();
        context.AppendLine($"Target phone: {phone}");
        if (result.IsSuccess && result.Data != null)
        {
            var network = result.Data;
            context.AppendLine($"Network nodes: {network.Nodes?.Count ?? 0}, Edges: {network.Edges?.Count ?? 0}");
            if (network.Nodes?.Any() == true)
            {
                context.AppendLine("Key suspects in network:");
                foreach (var n in network.Nodes.Take(10))
                    context.AppendLine($"- {n.SuspectName} ({n.PhoneNumber}) — Risk: {n.RiskLevel}, Role: {n.Role}");
            }
            if (network.Edges?.Any() == true)
            {
                context.AppendLine("Network connections:");
                foreach (var e in network.Edges.Take(10))
                    context.AppendLine($"- {e.SourcePhone} ↔ {e.TargetPhone}: {e.RelationType} (Calls: {e.CallCount})");
            }
            if (!string.IsNullOrEmpty(network.AIAnalysis))
                context.AppendLine($"Existing AI analysis: {network.AIAnalysis}");
        }

        var prompt = $@"You are an Indian law enforcement criminal network analysis expert AI.

User query: ""{query}""

{(context.Length > 0 ? $"Network data gathered:\n{context}" : $"No network data found for {phone}.")}

Provide a comprehensive suspect network analysis including:
1. Network structure and key players
2. Central figures and their roles
3. Communication patterns and relationships
4. Risk assessment of each suspect
5. Potential criminal organization structure
6. Recommended investigative actions
7. Which connections to prioritize

Format with proper markdown. Be professional and thorough.";

        var aiResult = await AgentService.SendMessageAsync(prompt, "Suspect network analysis for Indian law enforcement", _currentCts?.Token ?? CancellationToken.None);
        if (aiResult?.Success == true && !IsAgentRefusal(aiResult.Message))
            return aiResult.Message;

        // Fallback
        if (!result.IsSuccess || result.Data == null)
            return $"No network data found for {phone}. Ensure intelligence has been gathered first.";

        var fb = new System.Text.StringBuilder();
        fb.AppendLine($"## 🕸️ Suspect Network Analysis\n");
        fb.AppendLine($"- Total Nodes: **{result.Data.Nodes?.Count ?? 0}**");
        fb.AppendLine($"- Total Edges: **{result.Data.Edges?.Count ?? 0}**");
        if (result.Data.Nodes?.Any() == true)
        {
            fb.AppendLine("\n### Key Suspects");
            foreach (var n in result.Data.Nodes.Take(8))
                fb.AppendLine($"- **{n.SuspectName}** ({n.PhoneNumber}) — Risk: {n.RiskLevel}, Role: {n.Role}");
        }
        return fb.ToString();
    }

