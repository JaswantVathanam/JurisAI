    private string FormatMessage(string text)
    {
        if (string.IsNullOrEmpty(text)) return text;
        
        // Convert markdown formatting to HTML for rich rendering
        // Headers
        text = System.Text.RegularExpressions.Regex.Replace(text, @"^### (.+?)$", "<h4 class=\"chat-h4\">$1</h4>", System.Text.RegularExpressions.RegexOptions.Multiline);
        text = System.Text.RegularExpressions.Regex.Replace(text, @"^## (.+?)$", "<h3 class=\"chat-h3\">$1</h3>", System.Text.RegularExpressions.RegexOptions.Multiline);
        // Bold and italic
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\*\*\*(.+?)\*\*\*", "<strong><em>$1</em></strong>");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"(?<!\*)\*(?!\*)(.+?)(?<!\*)\*(?!\*)", "<em>$1</em>");
        // Inline code
        text = System.Text.RegularExpressions.Regex.Replace(text, @"`(.+?)`", "<code class=\"chat-code\">$1</code>");
        // Unordered lists (- items)
        text = System.Text.RegularExpressions.Regex.Replace(text, @"^- (.+?)$", "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        // Ordered lists (1. items)
        text = System.Text.RegularExpressions.Regex.Replace(text, @"^(\d+)\. (.+?)$", "<li>$2</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        // Wrap consecutive <li> in <ul>
        text = System.Text.RegularExpressions.Regex.Replace(text, @"((?:<li>.+?</li>\n?)+)", "<ul class=\"chat-list\">$1</ul>");
        // Horizontal rules
        text = System.Text.RegularExpressions.Regex.Replace(text, @"^---+$", "<hr class=\"chat-hr\"/>", System.Text.RegularExpressions.RegexOptions.Multiline);
        // Bullets
        text = System.Text.RegularExpressions.Regex.Replace(text, @"•\s*", "• ");
        // Line breaks (remaining newlines)
        text = text.Replace("\n", "<br/>");
        // Clean up extra <br/> around block elements
        text = System.Text.RegularExpressions.Regex.Replace(text, @"<br/>\s*(<h[34]|<ul|<hr)", "$1");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"(</h[34]>|</ul>|<hr[^>]*/>)\s*<br/>", "$1");
        
        return text;
    }

    private static bool IsAgentRefusal(string? message)
    {
        if (string.IsNullOrWhiteSpace(message)) return true;
        var lower = message.ToLowerInvariant();
        return lower.Contains("i'm sorry, but i cannot") ||
               lower.Contains("i cannot assist with that") ||
               lower.Contains("i can't assist with that") ||
               lower.Contains("i'm not able to help with") ||
               lower.Contains("i'm unable to") ||
               lower.Contains("as an ai, i cannot");
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isTyping) return;

        var query = userInput.Trim();
        userInput = string.Empty;

        // Handle confirmed actions (from permission flow)
        bool isConfirmedAction = query.StartsWith("[CONFIRMED] ");
        if (isConfirmedAction)
        {
            query = query["[CONFIRMED] ".Length..];
        }

        // Add user message
        ChatState.AddMessage(new ChatStateService.ChatMessage
        {
            Text = isConfirmedAction ? $"Confirmed: {query}" : query,
            IsUser = true,
            Timestamp = DateTime.Now
        });

        _currentCts = new CancellationTokenSource();
        ChatState.SetTyping(true);
        typingStatusText = "Thinking...";
        await Task.Delay(50);
        StateHasChanged();

        try
        {
            if (isFilingMode && currentFilingSession != null)
            {
                // Process through filing service (citizen only)
                await ProcessFilingResponseAsync(query);
            }
            else if (IsFilingIntent(query) && IsCitizenUser())
            {
                // Start complaint filing for citizens
                await StartCaseFilingAsync();
            }
            else if (pendingFollowUpIntent.HasValue)
            {
                // Route follow-up to the handler that requested more input
                var followUpIntent = pendingFollowUpIntent.Value;
                pendingFollowUpIntent = null;
                await ProcessSpecializedQueryAsync(query, followUpIntent);
            }
            else
            {
                // Always-on orchestration: detect all relevant agent domains
                var relevantDomains = OrchestratorSvc.DetectRelevantDomains(query);

                if (relevantDomains.Count > 0)
                {
                    // Check if this action requires user confirmation before proceeding
                    if (!isConfirmedAction && IsActionRequiringConfirmation(query))
                    {
                        ChatState.AddMessage(new ChatStateService.ChatMessage
                        {
                            Text = $"This action involves **{string.Join(", ", relevantDomains.Select(d => GetAgentDisplayName(d)))}** and may modify records.",
                            IsUser = false,
                            Timestamp = DateTime.Now,
                            AwaitingConfirmation = true,
                            ConfirmationPrompt = $"Do you want to proceed with: \"{query}\"?",
                            PendingAction = $"[CONFIRMED] {query}"
                        });
                    }
                    else
                    {
                        await ProcessOrchestratedQueryAsync(query, relevantDomains);
                    }
                }
                else if (IsCaseTrackingIntent(query) || IsPoliceUser() || IsLawyerUser())
                {
                    await ProcessRoleBasedQueryAsync(query);
                }
                else
                {
                    await GetRegularResponseAsync(query);
                }
            }
        }
        catch (OperationCanceledException)
        {
            ChatState.AddMessage(new ChatStateService.ChatMessage
            {
                Text = "⏹ Response generation was stopped.",
                IsUser = false,
                IsSystem = true,
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            _currentCts?.Dispose();
            _currentCts = null;
            ChatState.SetTyping(false);
            StateHasChanged();

            // Process queued follow-up if any
            if (!string.IsNullOrWhiteSpace(queuedMessage))
            {
                var nextQuery = queuedMessage;
                queuedMessage = null;
                await Task.Delay(300);
                userInput = nextQuery;
                StateHasChanged();
                await SendMessage();
            }
        }
    }

    private void StopGeneration()
    {
        _currentCts?.Cancel();
    }

    private void QueueFollowUp()
    {
        if (!string.IsNullOrWhiteSpace(userInput))
        {
            queuedMessage = userInput.Trim();
            userInput = string.Empty;
            StateHasChanged();
        }
    }

    private void ClearQueuedMessage()
    {
        queuedMessage = null;
        StateHasChanged();
    }

    private string GetInputPlaceholder()
    {
        if (isFilingMode) return "Type your response...";
        if (isTyping && string.IsNullOrWhiteSpace(queuedMessage)) return "Type a follow-up to queue...";
        if (!string.IsNullOrWhiteSpace(queuedMessage)) return "Follow-up already queued";
        return "Ask about laws, file complaints, or get legal help...";
    }

