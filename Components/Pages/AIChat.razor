    private async Task<string> HandleFIRDraftAsync(string query)
    {
        // Try to extract a case number from the query (e.g., CYB/2025/008, CRM/2024/012)
        var caseNumberMatch = System.Text.RegularExpressions.Regex.Match(
            query, @"\b(CYB|CRM|CVL|CON)[\/\-]\d{4}[\/\-]\d{2,4}\b", System.Text.RegularExpressions.RegexOptions.IgnoreCase);

        Case? matchedCase = null;
        if (caseNumberMatch.Success)
        {
            var caseNumber = caseNumberMatch.Value.Replace("-", "/").ToUpper();
            var searchResults = await CaseService.SearchCasesAsync(caseNumber);
            matchedCase = searchResults.FirstOrDefault();
        }
        else
        {
            // No case number found — try to search by keyword in case it's a plain description
            var searchResults = await CaseService.SearchCasesAsync(query);
            if (searchResults.Count == 1)
                matchedCase = searchResults.First();
            else if (searchResults.Count == 0)
            {
                // Ask user for case number and set follow-up intent so next message routes back here
                pendingFollowUpIntent = SpecializedIntent.FIRDraft;
                return "🛡️ To register an FIR, please specify the case number.\n\nExample: `Register FIR for CYB/2025/001`";
            }
        }

        // Build the FIR input draft from case data if available
        var inputDraft = new FIRDraft { IncidentDescription = query };
        if (matchedCase != null)
        {
            inputDraft.IncidentDescription = matchedCase.Description;
            inputDraft.IncidentDate = matchedCase.FiledDate;
            inputDraft.IncidentLocation = matchedCase.PoliceStation ?? "";
            inputDraft.PoliceStation = matchedCase.PoliceStation ?? "";
            inputDraft.ComplainantName = matchedCase.Complainant;
            inputDraft.AccusedName = matchedCase.Accused;
            if (matchedCase.CybercrimeCategory != null)
                inputDraft.CrimeType = FIRCrimeType.CyberCrime;
        }
        var draft = await FIRDraftSvc.GenerateFIRDraftAsync(inputDraft);

        var context = new System.Text.StringBuilder();

        // Add case database context if matched
        if (matchedCase != null)
        {
            context.AppendLine("=== CASE DATA FROM INTERNAL DATABASE ===");
            context.AppendLine($"Case Number: {matchedCase.CaseNumber}");
            context.AppendLine($"Title: {matchedCase.Title}");
            context.AppendLine($"Description: {matchedCase.Description}");
            context.AppendLine($"Type: {matchedCase.Type}");
            context.AppendLine($"Status: {matchedCase.Status}");
            context.AppendLine($"Filed Date: {matchedCase.FiledDate:dd MMM yyyy}");
            context.AppendLine($"Complainant: {matchedCase.Complainant}");
            context.AppendLine($"Accused: {matchedCase.Accused}");
            if (!string.IsNullOrEmpty(matchedCase.PoliceStation))
                context.AppendLine($"Police Station: {matchedCase.PoliceStation}");
            if (!string.IsNullOrEmpty(matchedCase.InvestigatingOfficer))
                context.AppendLine($"Investigating Officer: {matchedCase.InvestigatingOfficer}");
            if (!string.IsNullOrEmpty(matchedCase.FIRNumber))
                context.AppendLine($"Existing FIR Number: {matchedCase.FIRNumber}");
            if (matchedCase.IsCybercrime)
                context.AppendLine($"Cybercrime Category: {matchedCase.CybercrimeCategory}");
            if (!string.IsNullOrEmpty(matchedCase.DigitalEvidence))
                context.AppendLine($"Digital Evidence: {matchedCase.DigitalEvidence}");
            if (matchedCase.ApplicableLaws?.Count > 0)
                context.AppendLine($"Applicable Laws: {string.Join(", ", matchedCase.ApplicableLaws)}");
            if (matchedCase.Sections?.Count > 0)
                context.AppendLine($"Sections: {string.Join(", ", matchedCase.Sections)}");
            if (matchedCase.ApplicableSections?.Count > 0)
                context.AppendLine($"Applicable Sections: {string.Join(", ", matchedCase.ApplicableSections)}");
            if (!string.IsNullOrEmpty(matchedCase.AIAnalysis))
                context.AppendLine($"AI Analysis: {matchedCase.AIAnalysis}");
            if (matchedCase.TimelineEvents?.Count > 0)
            {
                context.AppendLine("\nTimeline Events:");
                foreach (var evt in matchedCase.TimelineEvents.OrderBy(e => e.EventDate))
                    context.AppendLine($"  - {evt.EventDate:dd MMM yyyy}: {evt.Title} - {evt.Description}");
            }
            context.AppendLine();
        }

        if (draft != null)
        {
            context.AppendLine("=== FIR DRAFT SERVICE OUTPUT ===");
            context.AppendLine($"Draft ID: {draft.Id}");
            context.AppendLine($"Incident Date: {draft.IncidentDate:dd MMM yyyy}");
            context.AppendLine($"Crime Type: {draft.CrimeType}");
            context.AppendLine($"Applicable Sections: {string.Join(", ", draft.ApplicableSections ?? new List<string>())}");
            context.AppendLine($"Description: {draft.IncidentDescription}");
            if (!string.IsNullOrEmpty(draft.LegalAnalysis))
                context.AppendLine($"Legal Analysis: {draft.LegalAnalysis}");
            if (!string.IsNullOrEmpty(draft.AIDraftedFIR))
                context.AppendLine($"AI Drafted FIR: {draft.AIDraftedFIR}");
        }

        var prompt = $@"You are an Indian law enforcement FIR drafting expert AI agent.

User query: ""{query}""

{(context.Length > 0 ? $"All available data from the internal case database and draft service:\n{context}" : "No case data was found in the database.")}

IMPORTANT: You are an AI agent with access to the internal case database. Use ALL the data provided above to generate the FIR.
Do NOT ask the user for information that is already available in the case data above.
Automatically populate every field you can from the database.

Generate a comprehensive FIR draft including:
1. A properly formatted FIR following Indian police format (with all fields auto-filled from case data)
2. Complainant details (from case data)
3. Accused details (from case data)
4. Incident description (detailed, from case data)
5. Applicable IPC/BNS/IT Act sections with brief explanations
6. Evidence already collected and evidence still needed
7. Next steps after FIR registration
8. Important reminders for the filing officer

Format with proper markdown. Include a disclaimer that this is a draft for review and verification.";

        var aiResult = await AgentService.SendMessageAsync(prompt, "FIR draft generation for Indian law enforcement", _currentCts?.Token ?? CancellationToken.None);
        if (aiResult?.Success == true && !IsAgentRefusal(aiResult.Message))
            return aiResult.Message;

        // Fallback
        if (draft == null)
            return "Unable to generate FIR draft. Please provide more details about the incident.";

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("## 📝 FIR Draft Generated\n");
        sb.AppendLine($"**Crime Type:** {draft.CrimeType}");
        sb.AppendLine($"**Applicable Sections:** {string.Join(", ", draft.ApplicableSections ?? new List<string>())}");
        sb.AppendLine($"\n**Incident Description:**\n{draft.IncidentDescription}");
        if (!string.IsNullOrEmpty(draft.AIDraftedFIR))
            sb.AppendLine($"\n### 📝 AI Drafted FIR\n{draft.AIDraftedFIR}");
        sb.AppendLine("\n_⚠️ This is a draft. Please review and edit before official filing._");
        return sb.ToString();
    }

