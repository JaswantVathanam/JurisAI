@page "/ai-chat"
@page "/chat"
@using System.Threading
@using AILegalAsst.Models
@using AILegalAsst.Services
@using static AILegalAsst.Services.ChatStateService
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject ChatStateService ChatState
@inject AzureAgentService AgentService
@inject AgentCaseFilingService FilingService
@inject AgentCaseManagementService CaseManagementService
@inject CaseService CaseService
@inject LanguageService LangService
@inject IJSRuntime JSRuntime
@inject SessionSecurityService SessionSecurity
@inject LawService LawSvc
@inject LegalDatabaseService LegalDbSvc
@inject PrecedentService PrecedentSvc
@inject LegalWebSearchService WebSearchSvc
@inject DeadlineTrackerService DeadlineSvc
@inject CybercrimeService CybercrimeSvc
@inject ScamPatternService ScamPatternSvc
@inject ScamRadarService ScamRadarSvc
@inject EmergencySOSService EmergencySvc
@inject FIRDraftService FIRDraftSvc
@inject EvidenceCustodyService EvidenceSvc
@inject LegalNoticeService LegalNoticeSvc
@inject CaseIQService CaseIQSvc
@inject PhoneIntelligenceService PhoneIntelSvc
@inject InvestigationWorkflowService WorkflowSvc
@inject CDRAnalysisService CDRSvc
@inject IntelligenceGatheringService IntelSvc
@inject DataSourceIntegrationService DataSourceSvc
@inject GeoIntelligenceService GeoIntelSvc
@inject SuspectNetworkService SuspectNetSvc
@inject AgentOrchestrationService OrchestratorSvc
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>JurisAI - Chat</PageTitle>
<link href="ai-chat.css" rel="stylesheet" />

<div class="ai-chat-page ai-chat-page-v2">
    <!-- Compact Action Bar -->
    <div class="chat-action-bar chat-action-bar-v2">
        <div class="action-bar-left action-bar-left-v2">
            <button class="btn-action btn-action-v2" @onclick="StartNewChat" title="New Chat">
                <i class="bi bi-plus-circle"></i> <span>New Chat</span>
            </button>
            <button class="btn-action btn-action-v2" @onclick="ToggleSidebar" title="Chat History">
                <i class="bi bi-clock-history"></i> <span>History</span>
            </button>
        </div>
        <div class="action-bar-right action-bar-right-v2">
            @if (isFilingMode)
            {
                <span class="filing-badge filing-badge-v2">
                    <i class="bi bi-file-earmark-text"></i> Filing Complaint
                </span>
            }
        </div>
    </div>

    <div class="chat-container chat-container-v2">
        <!-- Chat History Sidebar -->
        @if (showSidebar)
        {
            <div class="chat-sidebar chat-sidebar-v2">
                <div class="sidebar-header sidebar-header-v2">
                    <h3><i class="bi bi-chat-dots"></i> Chat History</h3>
                </div>
                <div class="chat-sessions chat-sessions-v2">
                    @foreach (var session in chatSessions)
                    {
                        <div class="session-card session-card-v2 @(session.Id == currentSessionId ? "active" : "")" 
                             @onclick="() => LoadSession(session.Id)">
                            <div class="session-content session-content-v2">
                                @if (editingSessionId == session.Id)
                                {
                                    <input type="text" class="session-title-edit session-title-edit-v2" 
                                           @bind="editingTitle" 
                                           @onblur="() => SaveSessionTitle(session.Id)"
                                           @onkeypress="(e) => HandleTitleKeyPress(e, session.Id)" />
                                }
                                else
                                {
                                    <div class="session-title session-title-v2">@session.Title</div>
                                }
                                <div class="session-date session-date-v2">@session.CreatedAt.ToString("MMM dd, yyyy")</div>
                            </div>
                            <div class="session-actions session-actions-v2" @onclick:stopPropagation="true">
                                <button class="btn-session-action btn-session-action-v2" @onclick="() => EditSessionTitle(session.Id, session.Title)" title="Edit Title">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn-session-action btn-session-action-v2 btn-delete btn-delete-v2" @onclick="() => DeleteSession(session.Id)" title="Delete Chat">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Main Chat Area -->
        <div class="chat-main chat-main-v2">
            <!-- Messages Container -->
            <div class="messages-container messages-container-v2" @ref="messagesContainer">
                @if (messages.Count == 0)
                {
                    <!-- Welcome Screen -->
                    <div class="welcome-screen welcome-screen-v2">
                        <div class="welcome-icon welcome-icon-v2">
                            <i class="bi bi-stars"></i>
                        </div>
                        <h2>Welcome, @(currentUser?.Name ?? "User")!</h2>
                        <p class="welcome-message-v2">@GetWelcomeMessage()</p>
                        
                        <!-- Quick Action Cards - Role Based -->
                        <div class="quick-actions-grid quick-actions-grid-v2">
                            @if (IsPoliceUser())
                            {
                                <!-- Police-specific Quick Actions -->
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Show my pending cases")'>
                                    <div class="action-icon action-icon-v2 police-cases">
                                        <i class="bi bi-folder2-open"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>Pending Cases</h4>
                                        <p>View complaints awaiting FIR registration</p>
                                    </div>
                                </div>
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Register FIR for a case")'>
                                    <div class="action-icon action-icon-v2 fir-action">
                                        <i class="bi bi-file-earmark-medical"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>Register FIR</h4>
                                        <p>Register First Information Report</p>
                                    </div>
                                </div>
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Update investigation status")'>
                                    <div class="action-icon action-icon-v2 investigation">
                                        <i class="bi bi-search"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>Update Investigation</h4>
                                        <p>Add investigation notes and findings</p>
                                    </div>
                                </div>
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Add evidence to a case")'>
                                    <div class="action-icon action-icon-v2 evidence">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>Collect Evidence</h4>
                                        <p>Upload and document case evidence</p>
                                    </div>
                                </div>
                            }
                            else if (IsLawyerUser())
                            {
                                <!-- Lawyer-specific Quick Actions -->
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Show my assigned cases")'>
                                    <div class="action-icon action-icon-v2 lawyer-cases">
                                        <i class="bi bi-briefcase"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>My Cases</h4>
                                        <p>View your assigned case portfolio</p>
                                    </div>
                                </div>
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Show cases available for assignment")'>
                                    <div class="action-icon action-icon-v2 available-cases">
                                        <i class="bi bi-clipboard-check"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>Available Cases</h4>
                                        <p>Cases ready for lawyer assignment</p>
                                    </div>
                                </div>
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Schedule a court hearing")'>
                                    <div class="action-icon action-icon-v2 hearing">
                                        <i class="bi bi-calendar-event"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>Schedule Hearing</h4>
                                        <p>Schedule court hearing dates</p>
                                    </div>
                                </div>
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Analyze case for legal strategy")'>
                                    <div class="action-icon action-icon-v2 legal-analysis">
                                        <i class="bi bi-journal-text"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>Case Analysis</h4>
                                        <p>Get AI-powered legal analysis</p>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <!-- Citizen Quick Actions (default) -->
                                <div class="quick-action-card quick-action-card-v2" @onclick="StartCaseFiling">
                                    <div class="action-icon action-icon-v2 file-complaint">
                                        <i class="bi bi-file-earmark-plus"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>File a Complaint</h4>
                                        <p>I'll guide you step-by-step to file your complaint</p>
                                    </div>
                                </div>
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Show my cases")'>
                                    <div class="action-icon action-icon-v2 my-cases">
                                        <i class="bi bi-folder2-open"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>My Cases</h4>
                                        <p>View all your filed complaints and their status</p>
                                    </div>
                                </div>
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Track my case progress")'>
                                    <div class="action-icon action-icon-v2 track-case">
                                        <i class="bi bi-graph-up-arrow"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>Track Progress</h4>
                                        <p>See timeline and workflow of your cases</p>
                                    </div>
                                </div>
                                <div class="quick-action-card quick-action-card-v2" @onclick='() => SendSuggestedQuestion("Show my cybercrime cases")'>
                                    <div class="action-icon action-icon-v2 cybercrime">
                                        <i class="bi bi-shield-exclamation"></i>
                                    </div>
                                    <div class="action-content action-content-v2">
                                        <h4>Cybercrime Cases</h4>
                                        <p>View cases categorized as cybercrime</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <!-- Message List -->
                    @foreach (var message in messages)
                    {
                        <div class="message message-v2 @(message.IsUser ? "user-message user-message-v2" : "ai-message ai-message-v2") @(message.IsSystem ? "system-message system-message-v2" : "")">
                            <div class="message-avatar message-avatar-v2">
                                @if (message.IsUser)
                                {
                                    <i class="bi bi-person-circle"></i>
                                }
                                else if (message.IsSystem)
                                {
                                    <i class="bi bi-info-circle"></i>
                                }
                                else
                                {
                                    <i class="bi bi-robot"></i>
                                }
                            </div>
                            <div class="message-content message-content-v2">
                                <div class="message-header message-header-v2">
                                    <span class="sender-name sender-name-v2">@(message.IsUser ? currentUser?.Name ?? "You" : message.IsSystem ? "System" : "JurisAI")</span>
                                    <span class="message-time message-time-v2">@message.Timestamp.ToString("hh:mm tt")</span>
                                </div>
                                <div class="message-text message-text-v2">
                                    @((MarkupString)FormatMessage(message.Text))
                                </div>
                                @if (message.IsOrchestrated && message.AgentActivities?.Any() == true)
                                {
                                    <div class="agent-activity-panel">
                                        <button class="agent-activity-toggle" @onclick="() => ToggleAgentPanel(message)">
                                            <svg class="agent-panel-icon" viewBox="0 0 24 24" width="16" height="16">
                                                <rect x="4" y="4" width="16" height="16" rx="3" fill="none" stroke="var(--gold-400, #ffa500)" stroke-width="1.8">
                                                    <animate attributeName="stroke-opacity" values="0.5;1;0.5" dur="2s" repeatCount="indefinite"/>
                                                </rect>
                                                <circle cx="9" cy="10" r="1.5" fill="var(--gold-400, #ffa500)">
                                                    <animate attributeName="opacity" values="0.4;1;0.4" dur="1.5s" repeatCount="indefinite"/>
                                                </circle>
                                                <circle cx="15" cy="10" r="1.5" fill="var(--gold-400, #ffa500)">
                                                    <animate attributeName="opacity" values="0.4;1;0.4" dur="1.5s" begin="0.3s" repeatCount="indefinite"/>
                                                </circle>
                                                <path d="M9 15 Q12 17 15 15" fill="none" stroke="var(--gold-400, #ffa500)" stroke-width="1.5" stroke-linecap="round">
                                                    <animate attributeName="d" values="M9 15 Q12 17 15 15;M9 14 Q12 16 15 14;M9 15 Q12 17 15 15" dur="2s" repeatCount="indefinite"/>
                                                </path>
                                            </svg>
                                            <span>@message.AgentActivities.Count(a => a.Status == ChatStateService.AgentStatus.Completed) of @message.AgentActivities.Count agents completed</span>
                                            <span class="agent-activity-time">
                                                @{
                                                    var totalMs = message.AgentActivities
                                                        .Where(a => a.StartTime.HasValue && a.EndTime.HasValue)
                                                        .Sum(a => (a.EndTime!.Value - a.StartTime!.Value).TotalMilliseconds);
                                                }
                                                @($"{totalMs / 1000.0:F1}s total")
                                            </span>
                                            <i class="bi @(IsAgentPanelExpanded(message) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                        </button>
                                        @if (IsAgentPanelExpanded(message))
                                        {
                                            <div class="agent-activity-list">
                                                @foreach (var activity in message.AgentActivities)
                                                {
                                                    <div class="agent-activity-item @activity.Status.ToString().ToLower()">
                                                        <div class="agent-activity-header" @onclick="() => activity.IsExpanded = !activity.IsExpanded">
                                                            <span class="agent-status-icon">
                                                                @switch (activity.Status)
                                                                {
                                                                    case ChatStateService.AgentStatus.Completed:
                                                                        <i class="bi bi-check-circle-fill text-success"></i>
                                                                        break;
                                                                    case ChatStateService.AgentStatus.Failed:
                                                                        <i class="bi bi-x-circle-fill text-danger"></i>
                                                                        break;
                                                                    case ChatStateService.AgentStatus.Running:
                                                                        <i class="bi bi-arrow-repeat spinning"></i>
                                                                        break;
                                                                    case ChatStateService.AgentStatus.Skipped:
                                                                        <i class="bi bi-dash-circle text-muted"></i>
                                                                        break;
                                                                    default:
                                                                        <i class="bi bi-circle text-muted"></i>
                                                                        break;
                                                                }
                                                            </span>
                                                            <span class="agent-name">@GetAgentDisplayName(activity.AgentName)</span>
                                                            <span class="agent-elapsed">@activity.ElapsedDisplay</span>
                                                            @if (!string.IsNullOrEmpty(activity.DataSummary) || !string.IsNullOrEmpty(activity.ErrorMessage))
                                                            {
                                                                <i class="bi @(activity.IsExpanded ? "bi-chevron-up" : "bi-chevron-down") agent-expand-icon"></i>
                                                            }
                                                        </div>
                                                        @if (activity.IsExpanded)
                                                        {
                                                            <div class="agent-activity-detail">
                                                                @if (!string.IsNullOrEmpty(activity.ErrorMessage))
                                                                {
                                                                    <span class="agent-error">Error: @activity.ErrorMessage</span>
                                                                }
                                                                else if (!string.IsNullOrEmpty(activity.DataSummary))
                                                                {
                                                                    <span class="agent-summary">@activity.DataSummary</span>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                @if (message.AwaitingConfirmation && !string.IsNullOrEmpty(message.ConfirmationPrompt))
                                {
                                    <div class="agent-confirmation-panel">
                                        <div class="confirmation-prompt">
                                            <svg class="confirmation-shield-icon" viewBox="0 0 24 24" width="20" height="20">
                                                <path d="M12 2 L3 7 V12 C3 17.5 7 21.5 12 23 C17 21.5 21 17.5 21 12 V7 Z" fill="none" stroke="var(--gold-400, #ffa500)" stroke-width="1.8">
                                                    <animate attributeName="stroke-opacity" values="0.6;1;0.6" dur="2s" repeatCount="indefinite"/>
                                                </path>
                                                <line x1="12" y1="9" x2="12" y2="14" stroke="var(--gold-400, #ffa500)" stroke-width="2" stroke-linecap="round"/>
                                                <circle cx="12" cy="17" r="1" fill="var(--gold-400, #ffa500)"/>
                                            </svg>
                                            @message.ConfirmationPrompt
                                        </div>
                                        <div class="confirmation-actions">
                                            <button class="btn-confirm" @onclick="() => HandleConfirmation(message, true)">
                                                <svg viewBox="0 0 16 16" width="14" height="14"><path d="M3 8 L7 12 L13 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                                Proceed
                                            </button>
                                            <button class="btn-deny" @onclick="() => HandleConfirmation(message, false)">
                                                <svg viewBox="0 0 16 16" width="14" height="14"><path d="M4 4 L12 12 M12 4 L4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                                Cancel
                                            </button>
                                        </div>
                                    </div>
                                }
                                @if (message.RelatedLaws?.Any() == true)
                                {
                                    <div class="related-laws related-laws-v2">
                                        <h4><i class="bi bi-link-45deg"></i> Related Laws:</h4>
                                        @foreach (var law in message.RelatedLaws)
                                        {
                                            <span class="law-chip law-chip-v2">@law</span>
                                        }
                                    </div>
                                }
                                @if (message.Options?.Any() == true)
                                {
                                    <div class="message-options message-options-v2">
                                        @foreach (var option in message.Options)
                                        {
                                            <button class="option-btn option-btn-v2" @onclick="() => SelectOption(option)">
                                                @option
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Typing Indicator -->
                    @if (isTyping)
                    {
                        <div class="message message-v2 ai-message ai-message-v2 typing">
                            <div class="message-avatar message-avatar-v2">
                                <svg class="avatar-spinner" viewBox="0 0 36 36" width="28" height="28">
                                    <circle cx="18" cy="18" r="15" fill="none" stroke="var(--gold-500)" stroke-width="2.5" stroke-dasharray="70 30" stroke-linecap="round">
                                        <animateTransform attributeName="transform" type="rotate" from="0 18 18" to="360 18 18" dur="1.2s" repeatCount="indefinite"/>
                                    </circle>
                                    <circle cx="18" cy="18" r="6" fill="var(--gold-400)" opacity="0.7">
                                        <animate attributeName="r" values="5;7;5" dur="1.5s" repeatCount="indefinite"/>
                                        <animate attributeName="opacity" values="0.5;1;0.5" dur="1.5s" repeatCount="indefinite"/>
                                    </circle>
                                </svg>
                            </div>
                            <div class="typing-indicator-wrapper typing-indicator-wrapper-v2">
                                <div class="typing-indicator typing-indicator-v2">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                                <span class="typing-status-text typing-status-text-v2">
                                    @((MarkupString)GetTypingStatusIcon()) @typingStatusText
                                </span>
                            </div>
                            <button class="btn-stop-generation" @onclick="StopGeneration" title="Stop generating">
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none">
                                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                                    <rect x="8" y="8" width="8" height="8" rx="1" fill="currentColor"/>
                                </svg>
                            </button>
                        </div>
                    }
                }
            </div>

            <!-- Suggested Questions (shown when not filing) -->
            @if (!isFilingMode && messages.Count > 0 && !showSuggestionsCollapsed)
            {
                <div class="suggestions-container suggestions-container-v2">
                    <div class="suggestions-header suggestions-header-v2">
                        <span class="suggestions-label suggestions-label-v2">
                            <i class="bi bi-lightning-fill"></i> Suggested
                        </span>
                        <button class="suggestions-toggle suggestions-toggle-v2" @onclick="() => showSuggestionsCollapsed = true">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                    <div class="suggestions-grid suggestions-grid-v2">
                        @foreach (var suggestion in suggestedQuestions.Take(4))
                        {
                            <button class="suggestion-chip suggestion-chip-v2" @onclick="() => SendSuggestedQuestion(suggestion)">
                                @suggestion
                            </button>
                        }
                    </div>
                </div>
            }

            <!-- Input Area -->
            <div class="chat-input-area chat-input-area-v2">
                @if (!isAgentReady && !AgentService.IsReady)
                {
                    <div class="agent-connecting-bar" style="padding: 4px 12px; font-size: 0.75rem; color: var(--gold-400); display: flex; align-items: center; gap: 6px;">
                        <span class="spinner-border spinner-border-sm" style="width: 12px; height: 12px;"></span>
                        <span>Connecting to AI Agent...</span>
                    </div>
                }
                @if (isFilingMode)
                {
                    <div class="filing-progress filing-progress-v2">
                        <div class="progress-bar progress-bar-v2">
                            <div class="progress-fill progress-fill-v2" style="width: @GetFilingProgress()%"></div>
                        </div>
                        <span class="progress-text progress-text-v2">@GetFilingStepText()</span>
                    </div>
                }
                <div class="input-container input-container-v2">
                    <textarea @bind="userInput" 
                              @bind:event="oninput"
                              @onkeydown="HandleKeyPress"
                              placeholder="@GetInputPlaceholder()"
                              rows="1"
                              class="chat-input chat-input-v2"></textarea>
                    @if (isTyping && !string.IsNullOrWhiteSpace(userInput))
                    {
                        <button class="btn-queue btn-queue-v2" @onclick="QueueFollowUp" title="Queue this message for after current response">
                            <svg viewBox="0 0 24 24" width="20" height="20" fill="none">
                                <path d="M4 6h16M4 12h16M4 18h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                <circle cx="19" cy="18" r="3" fill="var(--gold-400)">
                                    <animate attributeName="opacity" values="0.5;1;0.5" dur="1.5s" repeatCount="indefinite"/>
                                </circle>
                                <text x="17.5" y="20" fill="var(--navy-950)" font-size="5" font-weight="bold">+</text>
                            </svg>
                        </button>
                    }
                    <button class="btn-send btn-send-v2" @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(userInput) || isTyping)">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
                @if (!string.IsNullOrWhiteSpace(queuedMessage))
                {
                    <div class="queued-message-bar">
                        <svg class="queued-icon" viewBox="0 0 24 24" width="16" height="16" fill="none">
                            <path d="M4 6h16M4 12h16M4 18h10" stroke="var(--gold-400)" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span class="queued-text">Queued: @(queuedMessage.Length > 60 ? queuedMessage[..60] + "..." : queuedMessage)</span>
                        <button class="queued-clear" @onclick="ClearQueuedMessage" title="Remove queued message">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                }
                <div class="input-footer input-footer-v2">
                    @if (IsPoliceUser())
                    {
                        <button class="btn-role-action btn-role-action-v2 police" @onclick='() => SendSuggestedQuestion("Show my pending cases")'>
                            <i class="bi bi-folder2-open"></i> View Cases
                        </button>
                    }
                    else if (IsLawyerUser())
                    {
                        <button class="btn-role-action btn-role-action-v2 lawyer" @onclick='() => SendSuggestedQuestion("Show my assigned cases")'>
                            <i class="bi bi-briefcase"></i> My Cases
                        </button>
                    }
                    else if (isFilingMode)
                    {
                        <button class="btn-cancel-filing btn-cancel-filing-v2" @onclick="CancelFiling">
                            <i class="bi bi-x-circle"></i> Cancel Filing
                        </button>
                    }
                    else
                    {
                        <!-- Citizen buttons -->
                        <button class="btn-role-action btn-role-action-v2 citizen" @onclick='() => SendSuggestedQuestion("Show my cases")'>
