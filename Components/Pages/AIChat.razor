        }
    }

    private async Task SubmitVerification()
    {
        if (currentFilingSession == null) return;
        if (selectedVerificationMethod != IdentityVerificationMethod.BiometricConfirmation 
            && string.IsNullOrWhiteSpace(verificationPassword)) return;

        isVerifying = true;
        verificationError = string.Empty;
        StateHasChanged();

        try
        {
            var credential = selectedVerificationMethod switch
            {
                IdentityVerificationMethod.BiometricConfirmation => "biometric-verified",
                _ => verificationPassword
            };

            var result = await FilingService.ConfirmIdentityAsync(
                currentFilingSession.SessionId, credential, selectedVerificationMethod);

            if (result.IsVerified)
            {
                showVerificationModal = false;
                verificationPassword = string.Empty;
                verificationChallenge = null;

                ChatState.AddMessage(new ChatStateService.ChatMessage
                {
                    Text = "Identity verified successfully. Filing your case now...",
                    IsUser = false,
                    IsSystem = true,
                    Timestamp = DateTime.Now
                });
                StateHasChanged();

                // Now re-submit — identity is verified, so it will go through
                await ProcessFilingResponseAsync("Yes, Submit");
            }
            else
            {
                verificationError = result.Reason ?? "Verification failed. Please try again.";
                verificationAttemptsRemaining = result.AttemptsRemaining;

                if (verificationAttemptsRemaining <= 0)
                {
                    showVerificationModal = false;
                    isFilingMode = false;
                    currentFilingSession = null;
                    verificationChallenge = null;

                    ChatState.AddMessage(new ChatStateService.ChatMessage
                    {
                        Text = "## Session Terminated\n\nToo many failed verification attempts. Your filing session has been terminated for security. Please log in again to continue.",
                        IsUser = false,
                        IsSystem = true,
                        Timestamp = DateTime.Now
                    });
                }
            }
        }
        catch (Exception ex)
        {
            verificationError = $"Verification error: {ex.Message}";
        }
        finally
        {
            isVerifying = false;
            verificationPassword = string.Empty;
            StateHasChanged();
        }
    }

    private void SelectVerificationMethod(IdentityVerificationMethod method)
    {
        selectedVerificationMethod = method;
        verificationPassword = string.Empty;
        verificationError = string.Empty;
    }

    private async Task TriggerBiometric()
    {
        isVerifying = true;
        verificationError = string.Empty;
        StateHasChanged();

        try
        {
            var success = await JSRuntime.InvokeAsync<bool>("deviceFingerprint.requestBiometric");
            if (success)
            {
                verificationPassword = "biometric-verified";
                await SubmitVerification();
            }
            else
            {
                verificationError = "Biometric authentication was not completed. Try another method.";
            }
        }
        catch
        {
            verificationError = "Biometric authentication is not available on this device.";
        }
        finally
        {
            isVerifying = false;
            StateHasChanged();
        }
    }

