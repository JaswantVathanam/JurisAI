@* Identity Verification Modal — Platform-Aware *@
@if (showVerificationModal)
{
    <div class="verification-overlay" @onclick="CloseVerificationModal">
        <div class="verification-modal" @onclick:stopPropagation="true">
            <div class="verification-header">
                <i class="bi bi-shield-lock-fill"></i>
                <h3>Identity Verification Required</h3>
                @if (!string.IsNullOrEmpty(verificationChallenge?.PlatformLabel))
                {
                    <span class="platform-badge">
                        <i class="bi @GetPlatformIcon(verificationChallenge.PlatformLabel)"></i>
                        @verificationChallenge.PlatformLabel
                    </span>
                }
            </div>
            <div class="verification-body">
                <p>@(verificationChallenge?.Message ?? "Please verify your identity to continue.")</p>
                <div class="verification-user-info">
                    <i class="bi bi-person-circle"></i>
                    <span>@currentUser?.Email</span>
                </div>

                @* Verification method selector — show only if multiple methods available *@
                @if (verificationChallenge?.AvailableMethods?.Count > 1)
                {
                    <div class="verification-method-selector">
                        <label>Verification Method</label>
                        <div class="method-options">
                            @foreach (var method in verificationChallenge.AvailableMethods)
                            {
                                <button class="method-option @(selectedVerificationMethod == method ? "active" : "")" 
                                        @onclick="() => SelectVerificationMethod(method)" disabled="@isVerifying">
                                    <i class="bi @GetMethodIcon(method)"></i>
                                    <span>@GetMethodLabel(method)</span>
                                </button>
                            }
                        </div>
                    </div>
                }

                @* Input field — changes based on selected method *@
                <div class="verification-input-group">
                    <label>@GetMethodInputLabel(selectedVerificationMethod)</label>
                    @if (selectedVerificationMethod == IdentityVerificationMethod.BiometricConfirmation)
                    {
                        <button class="btn-biometric" @onclick="TriggerBiometric" disabled="@isVerifying">
                            <i class="bi bi-fingerprint"></i>
                            <span>Authenticate with @(verificationChallenge?.BiometricLabel ?? "Biometric")</span>
                        </button>
                    }
                    else
                    {
                        <input type="@(selectedVerificationMethod == IdentityVerificationMethod.TwoFactorOTP ? "text" : "password")"
                               @bind="verificationPassword" @bind:event="oninput"
                               @onkeypress="HandleVerificationKeyPress"
                               placeholder="@GetMethodPlaceholder(selectedVerificationMethod)"
                               maxlength="@(selectedVerificationMethod == IdentityVerificationMethod.TwoFactorOTP ? 6 : 100)"
                               class="verification-input" disabled="@isVerifying" />
                    }
                </div>

                @if (!string.IsNullOrEmpty(verificationError))
                {
                    <div class="verification-error">
                        <i class="bi bi-exclamation-triangle-fill"></i> @verificationError
                    </div>
                }
                @if (verificationAttemptsRemaining > 0 && verificationAttemptsRemaining < 3)
                {
                    <div class="verification-warning">
                        <i class="bi bi-exclamation-circle"></i> @verificationAttemptsRemaining attempt(s) remaining
                    </div>
                }
                @if (!string.IsNullOrEmpty(verificationChallenge?.SecurityNotes))
                {
                    <div class="verification-platform-note">
                        <i class="bi bi-info-circle"></i> @verificationChallenge.SecurityNotes
                    </div>
                }
            </div>
            <div class="verification-footer">
                <button class="btn-verify-cancel" @onclick="CloseVerificationModal" disabled="@isVerifying">Cancel</button>
                <button class="btn-verify-confirm" @onclick="SubmitVerification" 
                        disabled="@(isVerifying || (selectedVerificationMethod != IdentityVerificationMethod.BiometricConfirmation && string.IsNullOrWhiteSpace(verificationPassword)))">
                    @if (isVerifying)
                    {
                        <span class="spinner-border spinner-border-sm"></span> <span>Verifying...</span>
                    }
                    else
                    {
                        <i class="bi bi-shield-check"></i> <span>Verify & File</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private User? currentUser;
    private ElementReference messagesContainer;
    private string userInput = string.Empty;
    private bool showSidebar = false;
    private bool showSuggestions = true;
    private bool showSuggestionsCollapsed = false;

    // Filing mode state
    private bool isFilingMode = false;
    private FilingSession? currentFilingSession;

    // Follow-up intent: when a specialized handler asks for more input,
    // the next message routes back to that handler
    private SpecializedIntent? pendingFollowUpIntent = null;

    // Identity verification modal state
    private bool showVerificationModal = false;
    private string verificationPassword = string.Empty;
    private string verificationError = string.Empty;
    private bool isVerifying = false;
    private int verificationAttemptsRemaining = 3;
    private string deviceFingerprint = "web-default";
    private VerificationChallenge? verificationChallenge;
    private IdentityVerificationMethod selectedVerificationMethod = IdentityVerificationMethod.PasswordReEntry;

    // Use shared state from ChatStateService
    private List<ChatStateService.ChatMessage> messages => ChatState.Messages;
    private List<ChatStateService.ChatSession> chatSessions => ChatState.ChatSessions;
    private int currentSessionId => ChatState.CurrentSessionId;
    private bool isTyping => ChatState.IsTyping;
    private string typingStatusText = "Thinking...";
    private CancellationTokenSource? _currentCts;
    private string? queuedMessage;

    // Role-specific suggested questions
    private List<string> suggestedQuestions => GetRoleSuggestedQuestions();

    private int editingSessionId = -1;
    private string editingTitle = string.Empty;
    private bool isAgentReady = false;

    protected override void OnInitialized()
    {
        LangService.OnLanguageChanged += OnLanguageChanged;
        
        currentUser = AuthService.GetCurrentUser();
        
        if (currentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        ChatState.OnChange += StateHasChanged;
        ChatState.InitializeSessions();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Get full device profile with platform detection
                var profile = await JSRuntime.InvokeAsync<DeviceProfile>("deviceFingerprint.getDeviceProfile");
                if (profile != null && !string.IsNullOrEmpty(profile.Fingerprint))
                {
                    deviceFingerprint = profile.Fingerprint;
                    if (currentUser != null)
                    {
                        SessionSecurity.UpdateDeviceProfile(currentUser.Id, profile);
                        AuthService.UpdateDeviceFingerprint(deviceFingerprint);
                    }
                }
            }
            catch
            {
                try
                {
                    // Fallback to basic fingerprint
                    deviceFingerprint = await JSRuntime.InvokeAsync<string>("deviceFingerprint.generate");
                    if (currentUser != null)
                    {
                        AuthService.UpdateDeviceFingerprint(deviceFingerprint);
                    }
                }
                catch
                {
                    deviceFingerprint = "web-default";
                }
            }

            // Initialize the AI agent in background after page has rendered
            _ = Task.Run(async () =>
            {
                try
                {
                    var ready = await AgentService.InitializeAsync();
                    isAgentReady = ready;
                    await InvokeAsync(StateHasChanged);
                }
                catch
                {
                    // Agent init failed — will retry on first use
                }
            });
        }
    }

    public void Dispose()
    {
        ChatState.OnChange -= StateHasChanged;
        LangService.OnLanguageChanged -= OnLanguageChanged;
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    // Role detection helpers
    private bool IsPoliceUser() => currentUser?.Role == UserRole.Police;
    private bool IsLawyerUser() => currentUser?.Role == UserRole.Lawyer;
    private bool IsCitizenUser() => currentUser?.Role == UserRole.Citizen || 
                                    (!IsPoliceUser() && !IsLawyerUser() && currentUser?.Role != UserRole.Admin);

    private string GetWelcomeMessage()
    {
