    private async Task<string> HandleLawSearchAsync(string query)
    {
        var keywords = query.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Where(w => w.Length > 2)
            .Take(5)
            .ToArray();
        var searchTerm = string.Join(" ", keywords);
        var laws = LawSvc.SearchLaws(searchTerm);

        // Build context from local data
        var context = new System.Text.StringBuilder();
        if (laws?.Any() == true)
        {
            context.AppendLine("Matching laws from local database:");
            foreach (var law in laws.Take(5))
            {
                context.AppendLine($"- {law.Title} ({law.Type}, {law.ActNumber})");
                if (law.Sections?.Any() == true)
                    foreach (var sec in law.Sections.Take(3))
                        context.AppendLine($"  Section {sec.SectionNumber}: {sec.Title}");
            }
            if (laws.Count > 5) context.AppendLine($"...and {laws.Count - 5} more results.");
        }

        // Search online legal resources with timeout to avoid long waits
        typingStatusText = "Searching online legal resources...";
        StateHasChanged();

        List<OnlineLegalResult>? onlineResults = null;
        try
        {
            using var searchTimeoutCts = CancellationTokenSource.CreateLinkedTokenSource(_currentCts?.Token ?? CancellationToken.None);
            searchTimeoutCts.CancelAfter(TimeSpan.FromSeconds(8));
            onlineResults = await WebSearchSvc.SearchIndianKanoonAsync(query, 5, searchTimeoutCts.Token);
        }
        catch (OperationCanceledException)
        {
            // Online search timed out — continue with local data + AI knowledge
        }
        if (onlineResults?.Any() == true)
        {
            context.AppendLine("\nOnline search results from Indian Kanoon:");
            foreach (var result in onlineResults.Take(5))
            {
                context.AppendLine($"- {result.Title}");
                if (!string.IsNullOrWhiteSpace(result.Snippet))
                    context.AppendLine($"  {result.Snippet}");
                context.AppendLine($"  Source: {result.SourceUrl}");
            }
        }

        typingStatusText = "Analyzing legal provisions...";
        StateHasChanged();

        var onlineNote = onlineResults?.Any() == true
            ? "Online legal databases (Indian Kanoon) were also searched. Include relevant online findings and cite sources where possible."
            : "Online search returned no additional results.";

        var prompt = $@"You are an Indian legal expert AI assistant with deep knowledge of Indian law.

User query: ""{query}""

{(context.Length > 0 ? $"Relevant laws and sources found:\n{context}" : "No matching laws found in the local database.")}

{onlineNote}

IMPORTANT: In addition to the data above, use your OWN knowledge of Indian laws, statutes, IPC/BNS sections, CrPC/BNSS provisions, constitutional articles, and legal principles to provide a thorough answer. Do NOT limit yourself to only the data provided — supplement with your expertise.

Provide a comprehensive legal analysis including:
1. Relevant laws and sections applicable to the query (from data AND your own knowledge)
2. Key provisions and their implications
3. How these laws apply to the user's situation
4. Any recent amendments or important interpretations
5. Practical guidance
6. Source references (cite Indian Kanoon links if available)

Format with proper markdown.";

        var aiResult = await AgentService.SendMessageAsync(prompt, "Indian legal law search and analysis", _currentCts?.Token ?? CancellationToken.None);
        if (aiResult?.Success == true && !IsAgentRefusal(aiResult.Message))
            return aiResult.Message;

        // Fallback
        var sb = new System.Text.StringBuilder();
        if (laws?.Any() == true)
        {
            sb.AppendLine("## 📜 Relevant Laws Found\n");
            foreach (var law in laws.Take(5))
            {
                sb.AppendLine($"**{law.Title}** ({law.Type}, {law.ActNumber})");
                if (law.Sections?.Any() == true)
                    foreach (var sec in law.Sections.Take(3))
                        sb.AppendLine($"  Section {sec.SectionNumber}: {sec.Title}");
                sb.AppendLine($"Type: {law.Type}\n");
            }
            if (laws.Count > 5) sb.AppendLine($"_...and {laws.Count - 5} more results._");
        }
        if (onlineResults?.Any() == true)
        {
            sb.AppendLine("\n## 🌐 Online Results (Indian Kanoon)\n");
            foreach (var r in onlineResults.Take(5))
            {
                sb.AppendLine($"**{r.Title}**");
                if (!string.IsNullOrWhiteSpace(r.Snippet))
                    sb.AppendLine($"{r.Snippet}");
                sb.AppendLine($"[View on Indian Kanoon]({r.SourceUrl})\n");
            }
        }
        if (sb.Length > 0) return sb.ToString();
        return "No matching laws found. Try different keywords.";
    }

    private async Task<string> HandlePrecedentSearchAsync(string query)
