    // ── Agent Activity Panel Helpers ────────────────────────────────────

    private HashSet<int> expandedAgentPanels = new();

    private void ToggleAgentPanel(ChatStateService.ChatMessage message)
    {
        var hash = message.GetHashCode();
        if (!expandedAgentPanels.Add(hash))
            expandedAgentPanels.Remove(hash);
    }

    private bool IsAgentPanelExpanded(ChatStateService.ChatMessage message)
    {
        return expandedAgentPanels.Contains(message.GetHashCode());
    }

    private string GetAgentDisplayName(string agentName) => agentName switch
    {
        "CaseData" => "Case Database",
        "LawSearch" => "Law Search",
        "Precedent" => "Precedent Lookup",
        "Cybercrime" => "Cybercrime Intel",
        "ScamAnalysis" => "Scam Analysis",
        "Deadline" => "Deadline Tracker",
        "Evidence" => "Evidence Custody",
        "CDR" => "CDR Analysis",
        "Timeline" => "Case Timeline",
        "FIR" => "FIR Records",
        "LegalNotice" => "Legal Notices",
        _ => agentName
    };

    private async Task HandleConfirmation(ChatStateService.ChatMessage message, bool confirmed)
    {
        message.AwaitingConfirmation = false;
        if (confirmed && !string.IsNullOrEmpty(message.PendingAction))
        {
            // Send the confirmed action as a new user message
            userInput = message.PendingAction;
            StateHasChanged();
            await SendMessage();
        }
        else
        {
            ChatState.AddMessage(new ChatStateService.ChatMessage
            {
                Text = "Action cancelled by user.",
                IsUser = false,
                IsSystem = true,
                Timestamp = DateTime.Now
            });
            StateHasChanged();
        }
    }

    private bool IsActionRequiringConfirmation(string query)
    {
        var confirmationKeywords = new[] {
            "file fir", "register fir", "lodge fir",
            "send notice", "issue notice", "draft notice",
            "submit complaint", "file complaint",
            "delete case", "close case",
            "transfer case", "reassign"
        };
        return confirmationKeywords.Any(k => query.ToLowerInvariant().Contains(k));
    }

    private bool IsFilingIntent(string query)
    {
        var filingKeywords = new[] { "file a", "file new", "new complaint", "lodge complaint", "register complaint", "file complaint" };
        query = query.ToLower();
        return filingKeywords.Any(k => query.Contains(k));
    }

    private bool IsCaseTrackingIntent(string query)
    {
        var trackingKeywords = new[] { 
            "my cases", "my case", "filed cases", "show case", "list case", "track", "status", 
            "progress", "pending", "what happened", "update on", "how is my", "case details",
            "categorize", "category", "cybercrime cases", "all cases", "closed cases",
            "investigation", "fir status", "hearing", "court date", "lawyer", "timeline"
        };
        query = query.ToLower();
        return trackingKeywords.Any(k => query.Contains(k));
    }

    private async Task ProcessRoleBasedQueryAsync(string query)
    {
        if (currentUser == null) return;

        try
        {
            typingStatusText = "Consulting AI agent...";
            StateHasChanged();

            var response = await CaseManagementService.ProcessQueryAsync(query, currentUser);
            
            var message = new ChatStateService.ChatMessage
            {
                Text = response.Message,
                IsUser = false,
                Timestamp = DateTime.Now,
                Options = response.Actions?.Count > 0 ? response.Actions : null,
                RelatedLaws = response.RelatedLaws?.Count > 0 ? response.RelatedLaws : null
            };
            ChatState.AddMessage(message);

            // If case was updated, add system confirmation
            if (response.CaseUpdated && response.UpdatedCase != null)
            {
                ChatState.AddMessage(new ChatStateService.ChatMessage
                {
                    Text = $"✅ Case **{response.UpdatedCase.CaseNumber}** has been updated successfully.",
                    IsUser = false,
                    IsSystem = true,
                    Timestamp = DateTime.Now
                });
            }
        }
        catch (Exception ex)
        {
            ChatState.AddMessage(new ChatStateService.ChatMessage
            {
                Text = $"I encountered an issue processing your request. Please try again or rephrase your query.\n\nError: {ex.Message}",
                IsUser = false,
                Timestamp = DateTime.Now
            });
        }
    }

    private async Task ProcessFilingResponseAsync(string userResponse)
    {
        if (currentFilingSession == null) return;

        var response = await FilingService.ProcessUserResponseAsync(currentFilingSession.SessionId, userResponse);

        var message = new ChatStateService.ChatMessage
        {
            Text = response.Message,
            IsUser = false,
            Timestamp = DateTime.Now,
            Options = response.Options?.ToList()
        };
        ChatState.AddMessage(message);

        // Check if identity verification is required before filing
        if (response.RequiresIdentityVerification)
        {
            verificationChallenge = FilingService.RequestIdentityVerification(currentFilingSession.SessionId);
            selectedVerificationMethod = verificationChallenge?.RequiredMethod ?? IdentityVerificationMethod.PasswordReEntry;
            showVerificationModal = true;
            verificationPassword = string.Empty;
            verificationError = string.Empty;
            verificationAttemptsRemaining = 3;
            StateHasChanged();
            return;
        }

        if (response.IsComplete)
        {
            isFilingMode = false;
            currentFilingSession = null;

            // Add system message about the filed case
            if (!string.IsNullOrEmpty(response.CreatedCaseNumber))
            {
                ChatState.AddMessage(new ChatStateService.ChatMessage
                {
                    Text = $"Your case **{response.CreatedCaseNumber}** has been filed. You can track it in the Cases section.",
                    IsUser = false,
                    IsSystem = true,
                    Timestamp = DateTime.Now
                });
            }
        }
    }

    private async Task GetRegularResponseAsync(string query)
    {
        try
        {
            typingStatusText = "Consulting AI agent...";
            StateHasChanged();

            var userContext = currentUser != null 
                ? $"User Role: {currentUser.Role}, User Name: {currentUser.Name}" 
                : null;

            var history = messages
                .Select(m => new ConversationMessage
                {
                    Message = m.Text,
                    IsUser = m.IsUser,
                    Timestamp = m.Timestamp
                })
                .ToList();

            var agentResponse = await AgentService.SendMessageWithHistoryAsync(query, history, userContext, _currentCts?.Token ?? CancellationToken.None);

            ChatState.AddMessage(new ChatStateService.ChatMessage
            {
                Text = (agentResponse.Success && !IsAgentRefusal(agentResponse.Message)) ? agentResponse.Message : GenerateOfflineResponseText(query),
                IsUser = false,
                Timestamp = DateTime.Now,
                RelatedLaws = agentResponse.RelatedLaws
            });
        }
        catch
        {
            ChatState.AddMessage(new ChatStateService.ChatMessage
            {
                Text = GenerateOfflineResponseText(query),
                IsUser = false,
                Timestamp = DateTime.Now
            });
        }
    }

    private string GenerateOfflineResponseText(string query)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("## Offline Mode\n");
        sb.AppendLine("The AI service is currently unavailable, but you can still use the system's local features:\n");

        // Try to give useful direction based on what the user asked
        var lower = query.ToLowerInvariant();
        if (lower.Contains("case") || lower.Contains("fir") || lower.Contains("complaint"))
        {
            sb.AppendLine("**Your query appears to be about cases.** Navigate to the **Cases** page from the sidebar to view, search, and manage cases directly.\n");
        }
        else if (lower.Contains("law") || lower.Contains("section") || lower.Contains("act") || lower.Contains("bns") || lower.Contains("ipc"))
        {
            sb.AppendLine("**Your query appears to be about laws.** You can search Indian laws (BNS, BNSS, BSA, IT Act) using the sidebar. The local database is fully available offline.\n");
        }
        else if (lower.Contains("evidence") || lower.Contains("proof") || lower.Contains("forensic"))
        {
            sb.AppendLine("**Your query appears to be about evidence.** Navigate to the **Evidence** page to view chain of custody and evidence details.\n");
        }
        else if (lower.Contains("scam") || lower.Contains("fraud") || lower.Contains("cyber"))
        {
