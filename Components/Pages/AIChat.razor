    // ── Multi-Agent Orchestration ───────────────────────────────────────

    private async Task ProcessOrchestratedQueryAsync(string query, List<string> domains)
    {
        try
        {
            typingStatusText = $"Coordinating {domains.Count} agents: {string.Join(", ", domains)}...";
            StateHasChanged();

            var result = await OrchestratorSvc.OrchestrateAsync(
                query,
                domains,
                status =>
                {
                    typingStatusText = status;
                    InvokeAsync(StateHasChanged);
                },
                _currentCts?.Token ?? CancellationToken.None
            );

            if (result.Success && !string.IsNullOrWhiteSpace(result.SynthesizedResponse) && !IsAgentRefusal(result.SynthesizedResponse))
            {
                ChatState.AddMessage(new ChatStateService.ChatMessage
                {
                    Text = result.SynthesizedResponse,
                    IsUser = false,
                    Timestamp = DateTime.Now,
                    IsOrchestrated = true,
                    AgentActivities = result.Activities
                });
            }
            else
            {
                var fallback = OrchestratorSvc.FormatFallbackResponse(result);
                ChatState.AddMessage(new ChatStateService.ChatMessage
                {
                    Text = fallback,
                    IsUser = false,
                    Timestamp = DateTime.Now,
                    IsOrchestrated = true,
                    AgentActivities = result.Activities
                });
            }
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            // On orchestration failure, try the relevant specialized handler directly
            Console.WriteLine($"Orchestration failed, attempting direct handler fallback: {ex.Message}");
            try
            {
                string fallbackResponse = "";
                var primaryDomain = domains.FirstOrDefault();
                if (primaryDomain != null)
                {
                    fallbackResponse = primaryDomain switch
                    {
                        "LawSearch" => await HandleLawSearchAsync(query),
                        "CaseData" => "",  // Case data is handled by local services in orchestrator
                        "Precedent" => await HandlePrecedentSearchAsync(query),
                        "Cybercrime" => await HandleCybercrimeInfoAsync(query),
                        "ScamAnalysis" => await HandleScamAnalysisAsync(query),
                        "Deadline" => await HandleDeadlineInfoAsync(query),
                        "Evidence" => await HandleEvidenceInfoAsync(query),
                        "CDR" => await HandleCDRAnalysisAsync(query),
                        "FIR" => await HandleFIRDraftAsync(query),
                        "LegalNotice" => await HandleLegalNoticeAsync(query),
                        _ => ""
                    };
                }

                if (!string.IsNullOrWhiteSpace(fallbackResponse))
                {
                    ChatState.AddMessage(new ChatStateService.ChatMessage
                    {
                        Text = fallbackResponse,
                        IsUser = false,
                        Timestamp = DateTime.Now
                    });
                }
                else
                {
                    ChatState.AddMessage(new ChatStateService.ChatMessage
                    {
                        Text = GenerateOfflineResponseText(query),
                        IsUser = false,
                        Timestamp = DateTime.Now
                    });
                }
            }
            catch
            {
                ChatState.AddMessage(new ChatStateService.ChatMessage
                {
                    Text = GenerateOfflineResponseText(query),
                    IsUser = false,
                    Timestamp = DateTime.Now
                });
            }
        }
    }

