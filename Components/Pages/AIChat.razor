    private enum SpecializedIntent
    {
        None,
        LawSearch,
        PrecedentSearch,
        DeadlineInfo,
        CybercrimeInfo,
        ScamAnalysis,
        EmergencyHelp,
        FIRDraft,
        EvidenceInfo,
        LegalNotice,
        PhoneIntelligence,
        InvestigationHelp,
        CDRAnalysis,
        IntelligenceGathering,
        SuspectNetwork,
        GeoIntelligence,
        DataSourceQuery
    }

    private bool ContainsSpecialized(string q, params string[] keywords)
        => keywords.Any(k => q.Contains(k, StringComparison.OrdinalIgnoreCase));

    private SpecializedIntent DetectSpecializedIntent(string query)
    {
        var q = query.ToLower();

        if (ContainsSpecialized(q, "ipc", "crpc", "bns", "bnss", "section", "act ", "law ", "legal provision", "what law", "which section", "indian penal", "bharatiya nyaya"))
            return SpecializedIntent.LawSearch;

        if (ContainsSpecialized(q, "precedent", "landmark case", "supreme court", "high court", "court ruling", "case law", "judgment", "judgement"))
            return SpecializedIntent.PrecedentSearch;

        if (ContainsSpecialized(q, "deadline", "due date", "compliance", "overdue", "upcoming deadline", "deadline dashboard", "filing deadline"))
            return SpecializedIntent.DeadlineInfo;

        if (ContainsSpecialized(q, "cybercrime", "cyber crime", "online fraud", "hacking", "phishing", "cyber attack", "ransomware", "data breach", "cyber complaint"))
            return SpecializedIntent.CybercrimeInfo;

        if (ContainsSpecialized(q, "scam", "fraud analysis", "analyze scam", "is this a scam", "scam pattern", "scam radar", "community scam", "scam trend"))
            return SpecializedIntent.ScamAnalysis;

        if (ContainsSpecialized(q, "emergency", "sos", "urgent help", "helpline", "immediate danger", "wrongful detention", "police harassment", "domestic violence"))
            return SpecializedIntent.EmergencyHelp;

        if (ContainsSpecialized(q, "fir draft", "draft fir", "generate fir", "fir template", "first information report", "write fir", "register fir", "registerfir", "file fir"))
            return SpecializedIntent.FIRDraft;

        if (ContainsSpecialized(q, "evidence", "chain of custody", "evidence log", "forensic", "evidence integrity", "tamper", "custody chain"))
            return SpecializedIntent.EvidenceInfo;

        if (ContainsSpecialized(q, "legal notice", "send notice", "draft notice", "notice template", "cease and desist", "demand notice"))
            return SpecializedIntent.LegalNotice;

        if (ContainsSpecialized(q, "phone intel", "phone number", "mobile number", "caller id", "phone lookup", "number trace", "phone intelligence"))
            return SpecializedIntent.PhoneIntelligence;

        if (ContainsSpecialized(q, "investigation workflow", "investigation step", "next step", "investigation plan", "sop", "standard operating"))
            return SpecializedIntent.InvestigationHelp;

        if (ContainsSpecialized(q, "cdr", "call detail", "call record", "cdr analysis", "call data"))
            return SpecializedIntent.CDRAnalysis;

        if (ContainsSpecialized(q, "intelligence gather", "osint", "open source intelligence", "intel report", "surveillance", "gather intelligence"))
            return SpecializedIntent.IntelligenceGathering;

        if (ContainsSpecialized(q, "suspect network", "network analysis", "criminal network", "link analysis", "associate", "connection map"))
            return SpecializedIntent.SuspectNetwork;

        if (ContainsSpecialized(q, "geo intel", "geolocation", "location track", "geo intelligence", "map location", "location analysis"))
            return SpecializedIntent.GeoIntelligence;

        if (ContainsSpecialized(q, "data source", "external data", "api integration", "third party", "data feed", "integrate data"))
            return SpecializedIntent.DataSourceQuery;

        return SpecializedIntent.None;
    }

