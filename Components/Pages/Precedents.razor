    private void ToggleEditPrecedent()
    {
        if (selectedPrecedent == null) return;

        if (!isEditingPrecedent)
        {
            // Entering edit mode - save original state
            originalPrecedent = new Precedent
            {
                Id = selectedPrecedent.Id,
                CaseTitle = selectedPrecedent.CaseTitle,
                Citation = selectedPrecedent.Citation,
                CourtName = selectedPrecedent.CourtName,
                JudgeName = selectedPrecedent.JudgeName,
                JudgementDate = selectedPrecedent.JudgementDate,
                Summary = selectedPrecedent.Summary,
                JudgementText = selectedPrecedent.JudgementText,
                KeyPrinciples = selectedPrecedent.KeyPrinciples?.ToList(),
                ApplicableSections = selectedPrecedent.ApplicableSections?.ToList(),
                Keywords = selectedPrecedent.Keywords?.ToList(),
                IsCybercrimeRelated = selectedPrecedent.IsCybercrimeRelated
            };
            isEditingPrecedent = true;
        }
        else
        {
            // Canceling edit - restore original state
            if (originalPrecedent != null)
            {
                selectedPrecedent.CaseTitle = originalPrecedent.CaseTitle;
                selectedPrecedent.Citation = originalPrecedent.Citation;
                selectedPrecedent.CourtName = originalPrecedent.CourtName;
                selectedPrecedent.JudgeName = originalPrecedent.JudgeName;
                selectedPrecedent.JudgementDate = originalPrecedent.JudgementDate;
                selectedPrecedent.Summary = originalPrecedent.Summary;
                selectedPrecedent.JudgementText = originalPrecedent.JudgementText;
            }
            isEditingPrecedent = false;
            originalPrecedent = null;
        }
    }

    private async Task SavePrecedentChanges()
    {
        if (selectedPrecedent == null) return;

        try
        {
            await PrecedentService.UpdatePrecedentAsync(selectedPrecedent);
            
            // Reload the data to reflect changes
            allPrecedents = await PrecedentService.GetAllPrecedentsAsync();
            ApplyFilters();
            
            // Refresh the selected precedent
            selectedPrecedent = await PrecedentService.GetPrecedentByIdAsync(selectedPrecedent.Id);
            
            isEditingPrecedent = false;
            originalPrecedent = null;
            
            ShowToast("Precedent updated successfully!");
        }
        catch (Exception ex)
        {
            ShowToast($"Error updating precedent: {ex.Message}");
        }
    }

