    // Export Functionality
    private void ToggleExportMenu()
    {
        if (!isExporting)
        {
            showExportMenu = !showExportMenu;
        }
    }

    private async Task ExportPrecedents(string format)
    {
        showExportMenu = false;
        isExporting = true;
        StateHasChanged();

        var precedentsToExport = filteredPrecedents.ToList();

        if (!precedentsToExport.Any())
        {
            ShowToast("No precedents to export");
            isExporting = false;
            return;
        }

        try
        {
            await Task.Delay(1000); // Simulate export processing

            switch (format.ToLower())
            {
                case "csv":
                    ExportToCsv(precedentsToExport);
                    break;
                case "pdf":
                    ExportToPdf(precedentsToExport);
                    break;
                case "json":
                    ExportToJson(precedentsToExport);
                    break;
            }

            ShowToast($"Exported {precedentsToExport.Count} precedents as {format.ToUpper()}");
        }
        catch (Exception ex)
        {
            ShowToast($"Export failed: {ex.Message}");
        }
        finally
        {
            isExporting = false;
            StateHasChanged();
        }
    }

    private void ExportToCsv(List<Precedent> precedents)
    {
        var csv = "Case Title,Citation,Court,Judge,Judgement Date,Cybercrime Related,Keywords\n";
        csv += string.Join("\n", precedents.Select(p => 
            $"\"{p.CaseTitle}\",\"{p.Citation}\",\"{p.CourtName}\",\"{p.JudgeName}\"," +
            $"{p.JudgementDate:yyyy-MM-dd},{p.IsCybercrimeRelated}," +
            $"\"{string.Join("; ", p.Keywords ?? new List<string>())}\""
        ));

        var dataUrl = $"data:text/csv;charset=utf-8,{Uri.EscapeDataString(csv)}";
        var filename = $"precedents_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        JSRuntime.InvokeVoidAsync("downloadFile", dataUrl, filename);
    }

    private void ExportToPdf(List<Precedent> precedents)
    {
        var tableRows = string.Join("", precedents.Select(p => 
            "<tr>" +
                $"<td>{p.CaseTitle}</td>" +
                $"<td>{p.Citation}</td>" +
                $"<td>{p.CourtName}</td>" +
                $"<td>{p.JudgeName}</td>" +
                $"<td>{p.JudgementDate:MMM dd, yyyy}</td>" +
                $"<td>{(p.IsCybercrimeRelated ? "Yes" : "No")}</td>" +
            "</tr>"
        ));

        var html = $@"
        <html>
        <head>
            <style>
                body {{ font-family: Arial, sans-serif; margin: 20px; }}
                h1 {{ color: #333; border-bottom: 2px solid #d4af37; padding-bottom: 10px; }}
                table {{ width: 100%; border-collapse: collapse; margin-top: 20px; }}
                th, td {{ border: 1px solid #ddd; padding: 8px; text-align: left; }}
                th {{ background-color: #f5f5f5; font-weight: bold; }}
                .header {{ margin-bottom: 20px; }}
                .footer {{ margin-top: 20px; font-size: 0.9em; color: #888; }}
            </style>
        </head>
        <body>
            <div class='header'>
                <h1>JurisAI - Precedents Report</h1>
                <p>Generated: {DateTime.Now:MMMM dd, yyyy HH:mm}</p>
                <p>Total Precedents: {precedents.Count}</p>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Case Title</th>
                        <th>Citation</th>
                        <th>Court</th>
                        <th>Judge</th>
                        <th>Date</th>
                        <th>Cybercrime</th>
                    </tr>
                </thead>
                <tbody>
                    {tableRows}
                </tbody>
            </table>
            <div class='footer'>
                <p>Report generated by JurisAI</p>
            </div>
        </body>
        </html>";

        var dataUrl = $"data:text/html;charset=utf-8,{Uri.EscapeDataString(html)}";
        var filename = $"precedents_{DateTime.Now:yyyyMMdd_HHmmss}.html";
        JSRuntime.InvokeVoidAsync("downloadFile", dataUrl, filename);
    }

    private void ExportToJson(List<Precedent> precedents)
    {
        var json = System.Text.Json.JsonSerializer.Serialize(precedents.Select(p => new
        {
            p.CaseTitle,
            p.Citation,
            p.CourtName,
            p.JudgeName,
            JudgementDate = p.JudgementDate.ToString("yyyy-MM-dd"),
            p.IsCybercrimeRelated,
            p.Summary,
            p.Keywords,
            p.ApplicableSections
        }), new System.Text.Json.JsonSerializerOptions { WriteIndented = true });

        var dataUrl = $"data:application/json;charset=utf-8,{Uri.EscapeDataString(json)}";
        var filename = $"precedents_{DateTime.Now:yyyyMMdd_HHmmss}.json";
        JSRuntime.InvokeVoidAsync("downloadFile", dataUrl, filename);
    }

