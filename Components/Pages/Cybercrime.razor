                            </div>
                        }

                        @if (!string.IsNullOrEmpty(selectedReport.SuspectName) || !string.IsNullOrEmpty(selectedReport.SuspectContact))
                        {
                            <div class="report-section detail-section-v2">
                                <h3 class="detail-section-title-v2"><i class="bi bi-person-x"></i> Suspect Information</h3>
                                <div class="section-content section-content-v2">
                                    @if (!string.IsNullOrEmpty(selectedReport.SuspectName))
                                    {
                                        <p><strong>Name:</strong> @selectedReport.SuspectName</p>
                                    }
                                    @if (!string.IsNullOrEmpty(selectedReport.SuspectContact))
                                    {
                                        <p><strong>Contact:</strong> @selectedReport.SuspectContact</p>
                                    }
                                </div>
                            </div>
                        }

                        @if (selectedReport.ApplicableSections.Any())
                        {
                            <div class="report-section detail-section-v2">
                                <h3 class="detail-section-title-v2"><i class="bi bi-journal-bookmark"></i> Applicable Legal Sections</h3>
                                <div class="section-badges section-badges-v2">
                                    @foreach (var lawSection in selectedReport.ApplicableSections)
                                    {
                                        <span class="section-badge section-badge-v2">@lawSection</span>
                                    }
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(selectedReport.FIRNumber) || (isEditingReport && (currentUser?.Role == UserRole.Police || currentUser?.Role == UserRole.Admin)))
                        {
                            <div class="report-section detail-section-v2 fir-section fir-section-v2">
                                <div class="fir-badge fir-badge-v2">
                                    <i class="bi bi-file-earmark-check-fill"></i>
                                    <span>FIR @(string.IsNullOrEmpty(selectedReport.FIRNumber) ? "Details" : "Filed")</span>
                                </div>
                                <div class="fir-details fir-details-v2">
                                    <div class="fir-item fir-item-v2">
                                        <span class="label">FIR Number:</span>
                                        @if (isEditingReport && (currentUser?.Role == UserRole.Police || currentUser?.Role == UserRole.Admin))
                                        {
                                            <input type="text" class="form-control-inline form-input-v2" @bind="selectedReport.FIRNumber" 
                                                   placeholder="Enter FIR number" />
                                        }
                                        else
                                        {
                                            <span class="value">@selectedReport.FIRNumber</span>
                                        }
                                    </div>
                                    <div class="fir-item fir-item-v2">
                                        <span class="label">Filed Date:</span>
                                        @if (isEditingReport && (currentUser?.Role == UserRole.Police || currentUser?.Role == UserRole.Admin))
                                        {
                                            <input type="date" class="form-control-inline form-input-v2" 
                                                   value="@selectedReport.FIRFiledDate?.ToString("yyyy-MM-dd")"
                                                   @onchange="@((e) => selectedReport.FIRFiledDate = DateTime.Parse(e.Value?.ToString() ?? DateTime.Now.ToString()))" />
                                        }
                                        else
                                        {
                                            <span class="value">@selectedReport.FIRFiledDate?.ToString("MMM dd, yyyy")</span>
                                        }
                                    </div>
                                    <div class="fir-item fir-item-v2">
                                        <span class="label">Police Station:</span>
                                        @if (isEditingReport && (currentUser?.Role == UserRole.Police || currentUser?.Role == UserRole.Admin))
                                        {
                                            <input type="text" class="form-control-inline form-input-v2" @bind="selectedReport.PoliceStationName" 
                                                   placeholder="Enter police station name" />
                                        }
                                        else
                                        {
                                            <span class="value">@selectedReport.PoliceStationName</span>
                                        }
                                    </div>
                                </div>
