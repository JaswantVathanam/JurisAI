                            <div class="section-content section-content-v2">
                                @if (isEditingReport && (currentUser?.Role == UserRole.Police || currentUser?.Role == UserRole.Admin))
                                {
                                    <textarea class="form-control form-textarea-v2" rows="5" @bind="selectedReport.Description" 
