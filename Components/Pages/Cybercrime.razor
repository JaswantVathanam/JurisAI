                                            <span class="amount amount-v2">₹@selectedReport.FinancialLoss.Value.ToString("N2")</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(selectedReport.TransactionDetails))
                                    {
                                        <p><strong>Transaction Details:</strong> @selectedReport.TransactionDetails</p>
                                    }
