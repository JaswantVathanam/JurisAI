                                    <div class="info-icon info-icon-v2">
                                        <i class="bi bi-telephone"></i>
                                    </div>
                                    <div class="info-content info-content-v2">
                                        <label class="info-label-v2">Phone</label>
                                        <p class="info-value-v2">@selectedReport.VictimPhone</p>
