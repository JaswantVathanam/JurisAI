                </div>

                <div class="report-modal-body modal-body-v2">
                    <div class="report-details report-details-v2">
                        <div class="report-info-grid report-info-grid-v2">
                            <div class="info-card info-card-v2">
                                <div class="info-icon info-icon-v2">
                                    <i class="bi bi-exclamation-triangle"></i>
                                </div>
                                <div class="info-content info-content-v2">
                                    <label class="info-label-v2">Incident Type</label>
                                    <p class="info-value-v2">@GetCrimeTypeName(selectedReport.IncidentType)</p>
                                </div>
                            </div>
                            <div class="info-card info-card-v2">
                                <div class="info-icon info-icon-v2">
                                    <i class="bi bi-calendar-event"></i>
                                </div>
                                <div class="info-content info-content-v2">
                                    <label class="info-label-v2">Incident Date</label>
                                    <p class="info-value-v2">@selectedReport.IncidentDate.ToString("MMM dd, yyyy hh:mm tt")</p>
                                </div>
                            </div>
                            <div class="info-card info-card-v2">
                                <div class="info-icon info-icon-v2">
                                    <i class="bi bi-calendar-check"></i>
                                </div>
                                <div class="info-content info-content-v2">
                                    <label class="info-label-v2">Reported Date</label>
                                    <p class="info-value-v2">@selectedReport.ReportedDate.ToString("MMM dd, yyyy hh:mm tt")</p>
                                </div>
