                                    {
                                        <div class="timeline-item timeline-item-v2">
                                            <div class="timeline-marker timeline-marker-v2"></div>
                                            <div class="timeline-content timeline-content-v2">
                                                <div class="timeline-header timeline-header-v2">
                                                    <span class="timeline-date timeline-date-v2">@update.UpdateDate.ToString("MMM dd, yyyy")</span>
                                                    <span class="timeline-author timeline-author-v2">@update.UpdatedBy</span>
                                                </div>
                                                <p>@update.Message</p>
                                            </div>
                                        </div>
