                        @if (selectedReport.FinancialLoss.HasValue || !string.IsNullOrEmpty(selectedReport.TransactionDetails))
                        {
                            <div class="report-section detail-section-v2 highlight">
                                <h3 class="detail-section-title-v2"><i class="bi bi-currency-rupee"></i> Financial Details</h3>
                                <div class="section-content section-content-v2">
                                    @if (selectedReport.FinancialLoss.HasValue)
                                    {
                                        <div class="financial-loss financial-loss-v2">
