                        @if (currentUser?.Role == UserRole.Police)
                        {
                            <div class="detail-section detail-section-v2">
                                <h4 class="detail-section-title-v2">Investigation Actions</h4>
                                <div class="action-buttons action-buttons-v2">
                                    @if (selectedReport.Status == ReportStatus.UnderReview)
                                    {
                                        <button class="btn-primary btn-primary-v2" @onclick="StartInvestigation">
                                            <i class="bi bi-play-circle"></i> Start Investigation
                                        </button>
                                    }
                                    @if (selectedReport.Status == ReportStatus.InvestigationStarted && string.IsNullOrEmpty(selectedReport.FIRNumber))
                                    {
                                        <button class="btn-primary btn-primary-v2" @onclick="ShowFileFIRForm">
                                            <i class="bi bi-file-earmark-plus"></i> File FIR
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Law Details Modal -->
    @if (selectedLaw != null)
    {
        <div class="modal-overlay modal-overlay-v2" @onclick="CloseLawModal">
            <div class="modal-content law-modal-v2" @onclick:stopPropagation="true">
                <div class="modal-header modal-header-v2">
                    <h2 class="modal-title-v2">@selectedLaw.Title</h2>
                    <button class="close-btn modal-close-btn-v2" @onclick="CloseLawModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="modal-body modal-body-v2">
                    <div class="law-details law-details-v2">
                        <div class="law-badges law-badges-v2">
                            <span class="law-badge law-badge-v2">@selectedLaw.Category</span>
                            @if (selectedLaw.IsCybercrime)
                            {
                                <span class="law-badge law-badge-v2 cybercrime">Cybercrime</span>
                            }
                        </div>
                        <div class="law-section law-detail-section-v2">
                            <h4 class="detail-section-title-v2">Content</h4>
                            <p>@selectedLaw.Content</p>
