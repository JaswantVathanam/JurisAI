                                    <div class="info-icon info-icon-v2">
                                        <i class="bi bi-person-badge"></i>
                                    </div>
                                    <div class="info-content info-content-v2">
                                        <label class="info-label-v2">Name</label>
                                        <p class="info-value-v2">@selectedReport.VictimName</p>
                                    </div>
                                </div>
                                <div class="info-card info-card-v2">
                                    <div class="info-icon info-icon-v2">
                                        <i class="bi bi-envelope"></i>
                                    </div>
                                    <div class="info-content info-content-v2">
                                        <label class="info-label-v2">Email</label>
                                        <p class="info-value-v2">@selectedReport.VictimEmail</p>
