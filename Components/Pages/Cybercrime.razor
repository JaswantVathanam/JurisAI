    private void ApplySorting()
    {
        filteredReports = sortColumn switch
        {
            "date" => sortAscending ? 
                filteredReports.OrderBy(r => r.ReportedDate).ToList() : 
                filteredReports.OrderByDescending(r => r.ReportedDate).ToList(),
            "status" => sortAscending ? 
                filteredReports.OrderBy(r => r.Status).ToList() : 
                filteredReports.OrderByDescending(r => r.Status).ToList(),
            "type" => sortAscending ? 
                filteredReports.OrderBy(r => r.IncidentType).ToList() : 
                filteredReports.OrderByDescending(r => r.IncidentType).ToList(),
            "urgent" => sortAscending ? 
                filteredReports.OrderBy(r => r.IsUrgent).ToList() : 
                filteredReports.OrderByDescending(r => r.IsUrgent).ToList(),
            _ => filteredReports
        };
        sortAscending = !sortAscending;
    }

