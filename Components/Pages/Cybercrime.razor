    <!-- Toast Notification -->
    @if (showToast)
    {
        <div class="toast-notification toast-notification-v2" role="alert" aria-live="polite">
            <i class="bi bi-check-circle-fill"></i>
            <span>@toastMessage</span>
        </div>
    }
</div>
</CustomErrorBoundary>

@code {
    private User? currentUser;
    private string selectedView = "track";
    private CybercrimeReport newReport = new();
    private List<CybercrimeReport> allReports = new();
    private List<CybercrimeReport> userReports = new();
    private List<CybercrimeReport> assignedReports = new();
    private List<CybercrimeReport> filteredReports = new();
    private List<CybercrimeResource> emergencyResources = new();
    private List<CybercrimeResource> legalResources = new();
    private List<LawSection> itActSections = new();
    private CybercrimeStatistics statistics = new();
    private bool isLoadingAiInsight = false;
    private CybercrimeReport? selectedReport;
    private LawSection? selectedLaw;
    
    private string searchTerm = string.Empty;
    private string filterStatus = string.Empty;
    private string filterType = string.Empty;

    // Enhancement state variables
    private bool isLoading = false;
    private bool isExporting = false;
    private bool isPrinting = false;
    private bool showExportMenu = false;
    private bool showToast = false;
    private string toastMessage = string.Empty;
    private string sortColumn = "date";
    private bool sortAscending = false;
    
    // Edit mode state variables
    private bool isEditingReport = false;
    private CybercrimeReport? originalReport; // Store original state for cancel operation

    protected override async Task OnInitializedAsync()
    {
        LangService.OnLanguageChanged += OnLanguageChanged;
        currentUser = AuthService.GetCurrentUser();
        isLoading = true;
        await Task.Delay(300);
        LoadData();
        isLoading = false;
    }

    private async Task EnhanceWithAIInsight()
    {
        isLoadingAiInsight = true;
        try
        {
            var insight = await CybercrimeService.GetTrendInsightAsync(statistics);
            if (!string.IsNullOrEmpty(insight))
            {
                statistics.AiInsight = insight;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"AI insight load failed: {ex.Message}");
        }
        finally
        {
            isLoadingAiInsight = false;
        }
    }

    private void LoadData()
    {
        allReports = CybercrimeService.GetAllReports();
        statistics = CybercrimeService.GetStatistics();
        emergencyResources = CybercrimeService.GetEmergencyResources();
        legalResources = CybercrimeService.GetResourcesByCategory("Legal");
        
        // Get IT Act sections using LawType enum
        var itActLaw = LawService.GetAllLaws().FirstOrDefault(l => l.Title.Contains("Information Technology Act"));
        itActSections = itActLaw?.Sections ?? new List<LawSection>();

        if (currentUser != null)
        {
            if (currentUser.Role == UserRole.Citizen)
            {
                userReports = CybercrimeService.GetReportsByUser(currentUser.Id);
            }
            else if (currentUser.Role == UserRole.Police)
            {
                assignedReports = CybercrimeService.GetReportsByOfficer(currentUser.Id);
                filteredReports = allReports;
            }
        }
    }

    private void ShowReportForm()
    {
        selectedView = "form";
        newReport = new CybercrimeReport
        {
            VictimUserId = currentUser?.Id ?? 0,
            VictimName = currentUser?.Name ?? string.Empty,
            VictimEmail = currentUser?.Email ?? string.Empty,
            VictimPhone = string.Empty
        };
    }

    private void SubmitReport()
    {
        var createdReport = CybercrimeService.CreateReport(newReport);
        userReports.Insert(0, createdReport);
        selectedView = "track";
        newReport = new();
    }

    private void CancelReport()
    {
        selectedView = "track";
        newReport = new();
    }

    private void ViewReportDetails(CybercrimeReport report)
    {
        selectedReport = report;
    }

    private void CloseModal()
    {
        selectedReport = null;
        isEditingReport = false;
        originalReport = null;
    }

    private void ToggleEditMode()
    {
        if (!isEditingReport)
        {
            // Entering edit mode - save original state
            originalReport = new CybercrimeReport
            {
                Id = selectedReport!.Id,
                Title = selectedReport.Title,
                Description = selectedReport.Description,
                Status = selectedReport.Status,
                AssignedOfficerName = selectedReport.AssignedOfficerName,
                FIRNumber = selectedReport.FIRNumber,
                FIRFiledDate = selectedReport.FIRFiledDate,
                PoliceStationName = selectedReport.PoliceStationName
            };
            isEditingReport = true;
        }
        else
        {
            // Canceling edit - restore original state
            if (originalReport != null && selectedReport != null)
            {
                selectedReport.Title = originalReport.Title;
                selectedReport.Description = originalReport.Description;
                selectedReport.Status = originalReport.Status;
                selectedReport.AssignedOfficerName = originalReport.AssignedOfficerName;
                selectedReport.FIRNumber = originalReport.FIRNumber;
                selectedReport.FIRFiledDate = originalReport.FIRFiledDate;
                selectedReport.PoliceStationName = originalReport.PoliceStationName;
            }
            isEditingReport = false;
            originalReport = null;
        }
    }

    private void SaveReportChanges()
    {
        if (selectedReport == null) return;

        // Update the report in the service
        CybercrimeService.UpdateReport(selectedReport);
        
        // Reload data to reflect changes
        LoadData();
        
        // Exit edit mode
        isEditingReport = false;
        originalReport = null;
        
        // Show success toast
        ShowToast("Report updated successfully!");
    }

    private void ViewLawDetails(LawSection lawSection)
    {
        selectedLaw = lawSection;
    }

    private void CloseLawModal()
    {
        selectedLaw = null;
    }

    private void StartInvestigation()
    {
        if (selectedReport != null && currentUser != null)
        {
            CybercrimeService.UpdateReportStatus(
                selectedReport.Id,
                ReportStatus.InvestigationStarted,
                currentUser.Name,
                "Investigation has been initiated. Evidence collection in progress."
            );
            LoadData();
            CloseModal();
        }
    }

