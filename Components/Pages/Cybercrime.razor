                        @if (!string.IsNullOrEmpty(selectedReport.AssignedOfficerName) || (isEditingReport && (currentUser?.Role == UserRole.Police || currentUser?.Role == UserRole.Admin)))
                        {
                            <div class="report-section detail-section-v2">
                                <h3 class="detail-section-title-v2"><i class="bi bi-shield-check"></i> Assigned Officer</h3>
