    private string GetCrimeTypeName(CybercrimeType type)
    {
        return type switch
        {
            CybercrimeType.OnlineFraud => "Online Fraud",
            CybercrimeType.IdentityTheft => "Identity Theft",
            CybercrimeType.Cyberstalking => "Cyber Stalking",
            CybercrimeType.DataBreach => "Data Breach",
            CybercrimeType.SocialMediaAbuse => "Social Media Abuse",
            CybercrimeType.OnlineHarassment => "Online Harassment",
            CybercrimeType.ChildPornography => "Child Pornography",
            CybercrimeType.Cyberbullying => "Cyber Bullying",
            CybercrimeType.BankingFraud => "Banking Fraud",
            CybercrimeType.CreditCardFraud => "Credit Card Fraud",
            CybercrimeType.UPIFraud => "UPI Fraud",
            CybercrimeType.EcommerceScam => "E-commerce Scam",
            CybercrimeType.JobScam => "Job Scam",
            CybercrimeType.MatrimonialScam => "Matrimonial Scam",
            CybercrimeType.Ransomware => "Ransomware",
            _ => type.ToString()
