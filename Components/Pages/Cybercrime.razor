@page "/cybercrime"
@using AILegalAsst.Models
@using AILegalAsst.Services
@using AILegalAsst.Components.Shared
@inject CybercrimeService CybercrimeService
@inject AuthenticationService AuthService
@inject LanguageService LangService
@inject LawService LawService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Cybercrime Focus - JurisAI</PageTitle>

<link rel="stylesheet" href="cybercrime-enhancements.css" />
<link rel="stylesheet" href="cybercrime-print.css" media="print" />
<script src="app-utilities.js"></script>

<CustomErrorBoundary ShowDetails="true" ShowReportButton="true">
<div class="cybercrime-page cybercrime-page-v2">
    <!-- Print-Only Header -->
    <div class="print-only print-header">
        <h1>Cybercrime Reports</h1>
        <p class="print-meta">Generated: @DateTime.Now.ToString("MMMM dd, yyyy") | User: @currentUser?.Name</p>
    </div>

    <div class="page-header cybercrime-page-header-v2">
        <div class="header-content header-content-v2">
            <div class="header-icon header-icon-v2">
                <i class="bi bi-shield-exclamation"></i>
            </div>
            <div class="header-text header-text-v2">
                <h1>Cybercrime Focus</h1>
                <p class="header-subtitle header-subtitle-v2">Report, Track & Combat Cybercrimes</p>
            </div>
        </div>
        <div class="header-actions header-actions-v2 no-print">
            <div class="export-section">
                <button class="btn btn-export btn-export-v2" @onclick="ToggleExportMenu" disabled="@isExporting" aria-label="Export reports" aria-haspopup="menu" aria-expanded="@showExportMenu">
                    <i class="bi bi-download"></i>
                    <span>Export</span>
                    <i class="bi bi-chevron-down ms-1"></i>
                </button>
                @if (showExportMenu)
                {
                    <div class="export-dropdown export-dropdown-v2" role="menu">
                        <button class="dropdown-item export-option-v2" @onclick="@(() => ExportReports("csv"))" role="menuitem" tabindex="0">
                            <i class="bi bi-filetype-csv"></i>
                            <span>Export as CSV</span>
                        </button>
                        <button class="dropdown-item export-option-v2" @onclick="@(() => ExportReports("pdf"))" role="menuitem" tabindex="0">
                            <i class="bi bi-file-earmark-pdf"></i>
                            <span>Export as PDF</span>
                        </button>
                        <button class="dropdown-item export-option-v2" @onclick="@(() => ExportReports("json"))" role="menuitem" tabindex="0">
                            <i class="bi bi-filetype-json"></i>
                            <span>Export as JSON</span>
                        </button>
                    </div>
                }
            </div>
            <button class="btn btn-print btn-print-v2" @onclick="PrintReports" disabled="@isPrinting" aria-label="Print reports">
                <i class="bi bi-printer"></i>
                <span>Print</span>
            </button>
        </div>
    </div>

    @if (currentUser == null)
    {
        <div class="error-container error-container-v2">
            <p>Please log in to access this page.</p>
        </div>
    }
    else if (currentUser.Role == UserRole.Citizen)
    {
        <div class="citizen-view citizen-view-v2">
            <!-- Statistics Dashboard - Fixed Grid -->
            @if (isLoading)
            {
                <div class="skeleton-stats-grid skeleton-stats-grid-v2" role="status" aria-label="Loading statistics">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="skeleton-stat-card skeleton-stat-card-v2">
                            <div class="skeleton-stat-icon skeleton-stat-icon-v2"></div>
                            <div class="skeleton-stat-content skeleton-stat-content-v2">
                                <div class="skeleton-stat-value skeleton-stat-value-v2"></div>
                                <div class="skeleton-stat-label skeleton-stat-label-v2"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="stats-grid-fixed stats-grid-v2">
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-file-text"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@userReports.Count</h3>
                            <p>My Reports</p>
                        </div>
                    </div>
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@userReports.Count(r => r.Status == ReportStatus.UnderReview || r.Status == ReportStatus.InvestigationStarted)</h3>
                            <p>Active Cases</p>
                        </div>
                    </div>
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-check-circle"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@userReports.Count(r => r.Status == ReportStatus.Closed)</h3>
                            <p>Resolved</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Action Buttons -->
            <div class="action-buttons action-buttons-v2">
                <button class="btn-primary btn-primary-v2" @onclick="ShowReportForm">
                    <i class="bi bi-plus-circle"></i> File New Report
                </button>
                <button class="btn-secondary btn-secondary-v2" @onclick='() => selectedView = "track"'>
                    <i class="bi bi-search"></i> Track Report
                </button>
            </div>

            @if (selectedView == "form")
            {
                <!-- Report Form -->
                <div class="report-form-container report-form-container-v2">
                    <h2 class="form-title-v2">File Cybercrime Report</h2>
                    <form class="report-form report-form-v2" @onsubmit="SubmitReport">
                        <div class="form-group form-group-v2">
                            <label class="form-label-v2">Incident Type *</label>
                            <select class="form-select-v2" @bind="newReport.IncidentType" required>
                                <option value="">-- Select Type --</option>
                                @foreach (CybercrimeType type in Enum.GetValues(typeof(CybercrimeType)))
                                {
                                    <option value="@type">@GetCrimeTypeName(type)</option>
                                }
                            </select>
                        </div>

                        <div class="form-group form-group-v2">
                            <label class="form-label-v2">Title *</label>
                            <input type="text" class="form-input-v2" @bind="newReport.Title" placeholder="Brief description of incident" required />
                        </div>

                        <div class="form-group form-group-v2">
                            <label class="form-label-v2">Detailed Description *</label>
                            <textarea class="form-textarea-v2" @bind="newReport.Description" rows="5" placeholder="Provide detailed information about the incident..." required></textarea>
                        </div>

                        <div class="form-row form-row-v2">
                            <div class="form-group form-group-v2">
                                <label class="form-label-v2">Incident Date & Time *</label>
                                <input type="datetime-local" class="form-input-v2" @bind="newReport.IncidentDate" required />
                            </div>
                            <div class="form-group form-group-v2">
                                <label class="form-label-v2">Location</label>
                                <input type="text" class="form-input-v2" @bind="newReport.Location" placeholder="City, State" />
                            </div>
                        </div>

                        <div class="form-group form-group-v2">
                            <label class="form-label-v2">Financial Loss (if any)</label>
                            <input type="number" class="form-input-v2" @bind="newReport.FinancialLoss" placeholder="Amount in ₹" min="0" />
                        </div>

                        <div class="form-group form-group-v2">
                            <label class="form-label-v2">Transaction Details (for financial frauds)</label>
                            <textarea class="form-textarea-v2" @bind="newReport.TransactionDetails" rows="3" placeholder="UPI ID, Transaction ID, Bank details, etc."></textarea>
                        </div>

                        <div class="form-group form-group-v2">
                            <label class="form-label-v2">Suspect Information (if known)</label>
                            <input type="text" class="form-input-v2" @bind="newReport.SuspectName" placeholder="Name" />
                            <input type="text" class="form-input-v2 mt-2" @bind="newReport.SuspectContact" placeholder="Phone/Email/Social Media Handle" />
                        </div>

                        <div class="form-actions form-actions-v2">
                            <button type="submit" class="btn-primary btn-primary-v2">
                                <i class="bi bi-check-circle"></i> Submit Report
                            </button>
                            <button type="button" class="btn-secondary btn-secondary-v2" @onclick="CancelReport">
                                <i class="bi bi-x-circle"></i> Cancel
                            </button>
                        </div>
                    </form>
                </div>
            }
            else if (selectedView == "track")
            {
                <!-- My Reports - Fixed Grid Layout -->
                <div class="reports-container reports-container-v2">
                    <h2 class="section-title-v2">My Reports</h2>
                    @if (userReports.Any())
                    {
                        <div class="reports-grid reports-grid-v2">
                            @foreach (var report in userReports)
                            {
                                <div class="report-card-fixed report-card-v2" @onclick="() => ViewReportDetails(report)">
                                    <div class="report-card-header-fixed report-card-header-v2">
                                        <span class="report-number-badge report-number-badge-v2">
                                            <i class="bi bi-file-earmark-text"></i>
                                            @report.ReportNumber
                                        </span>
                                        <span class="status-badge-fixed status-badge-v2 status-@report.Status.ToString().ToLower().Replace("_","")">
                                            @report.Status.ToString().Replace("_", " ")
                                        </span>
                                    </div>
                                    <div class="report-card-body report-card-body-v2">
                                        <h3 class="report-title-v2">@report.Title</h3>
                                        <p class="report-description-v2">@report.Description</p>
                                        <div class="report-meta-grid report-meta-grid-v2">
                                            <div class="report-meta-item report-meta-item-v2">
                                                <i class="bi bi-calendar"></i>
                                                <span>@report.ReportedDate.ToString("MMM dd")</span>
                                            </div>
                                            <div class="report-meta-item report-meta-item-v2">
                                                <i class="bi bi-tag"></i>
                                                <span>@GetCrimeTypeName(report.IncidentType)</span>
                                            </div>
                                            @if (report.FinancialLoss.HasValue)
                                            {
                                                <div class="report-meta-item report-meta-item-v2">
                                                    <i class="bi bi-currency-rupee"></i>
                                                    <span>₹@report.FinancialLoss.Value.ToString("N0")</span>
                                                </div>
                                            }
                                            @if (report.IsUrgent)
                                            {
                                                <div class="report-meta-item report-meta-item-v2 urgent">
                                                    <i class="bi bi-exclamation-triangle"></i>
                                                    <span>Urgent</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state empty-state-v2">
                            <i class="bi bi-inbox"></i>
                            <p>No reports filed yet</p>
                            <button class="btn-primary btn-primary-v2" @onclick="ShowReportForm">File Your First Report</button>
                        </div>
                    }
                </div>
            }

            <!-- Resources Section -->
            <div class="resources-section resources-section-v2">
                <h2 class="section-title-v2">Helpful Resources</h2>
                <div class="resource-grid resource-grid-v2">
                    @foreach (var resource in emergencyResources.Take(3))
                    {
                        <div class="resource-card resource-card-v2 emergency">
                            <div class="resource-icon resource-icon-v2">
                                <i class="@resource.IconClass"></i>
                            </div>
                            <h3 class="resource-title-v2">@resource.Title</h3>
                            <p class="resource-description-v2">@resource.Description</p>
                            @if (!string.IsNullOrEmpty(resource.PhoneNumber))
                            {
                                <a href="tel:@resource.PhoneNumber" class="resource-link resource-link-v2">
                                    <i class="bi bi-telephone"></i> @resource.PhoneNumber
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(resource.Link))
                            {
                                <a href="@resource.Link" target="_blank" class="resource-link resource-link-v2">
                                    <i class="bi bi-box-arrow-up-right"></i> Visit Website
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else if (currentUser.Role == UserRole.Lawyer)
    {
        <div class="lawyer-view lawyer-view-v2">
            <div class="page-header role-header-v2">
                <div class="header-content header-content-v2">
                    <div class="header-icon header-icon-v2 lawyer-icon">
                        <i class="bi bi-briefcase"></i>
                    </div>
                    <div class="header-text header-text-v2">
                        <h1>Cybercrime Legal Resources</h1>
                        <p class="header-subtitle header-subtitle-v2">Legal Framework & Case Management</p>
                    </div>
                </div>
            </div>

            <!-- Statistics Overview - Fixed Grid -->
            @if (isLoading)
            {
                <div class="skeleton-stats-grid skeleton-stats-grid-v2" role="status" aria-label="Loading statistics">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="skeleton-stat-card skeleton-stat-card-v2">
                            <div class="skeleton-stat-icon skeleton-stat-icon-v2"></div>
                            <div class="skeleton-stat-content skeleton-stat-content-v2">
                                <div class="skeleton-stat-value skeleton-stat-value-v2"></div>
                                <div class="skeleton-stat-label skeleton-stat-label-v2"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="stats-grid-fixed stats-grid-v2">
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-file-text"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@statistics.TotalReports</h3>
                            <p>Total Reports</p>
                        </div>
                    </div>
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@statistics.ActiveInvestigations</h3>
                            <p>Active Cases</p>
                        </div>
                    </div>
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-currency-rupee"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>₹@(statistics.TotalFinancialLoss / 100000)L</h3>
                            <p>Financial Impact</p>
                        </div>
                    </div>
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-file-earmark-check"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@statistics.FIRsFiled</h3>
                            <p>FIRs Filed</p>
                        </div>
                    </div>
                </div>
            }

            <!-- AI Trend Insight -->
            <div style="margin: 1rem 0; padding: 1rem; background: rgba(102, 126, 234, 0.08); border-radius: 12px; border: 1px solid rgba(102, 126, 234, 0.2);">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;">
                    <span style="font-weight: 600; color: var(--text-primary); display: flex; align-items: center; gap: 0.5rem;"><i class="bi bi-lightbulb" style="color: #667eea;"></i> AI Trend Insight</span>
                    <button @onclick="EnhanceWithAIInsight" disabled="@isLoadingAiInsight" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 8px; border: none; background: linear-gradient(135deg, #667eea, #764ba2); color: white; cursor: pointer; display: flex; align-items: center; gap: 0.4rem;">
                        @if (isLoadingAiInsight)
                        {
                            <i class="bi bi-hourglass-split"></i> <span>Analyzing...</span>
                        }
                        else
                        {
                            <i class="bi bi-stars"></i> <span>@(string.IsNullOrEmpty(statistics.AiInsight) ? "Get AI Insight" : "Refresh Insight")</span>
                        }
                    </button>
                </div>
                <p style="color: var(--text-secondary); font-size: 0.9rem; margin: 0;">@(string.IsNullOrEmpty(statistics.AiInsight) ? "Click the button to generate AI-powered trend analysis." : statistics.AiInsight)</p>
            </div>

            <!-- IT Act Sections - Modern Card Grid -->
            <div class="laws-section laws-section-v2">
                <h2 class="section-title-v2"><i class="bi bi-journal-bookmark"></i> Applicable IT Act Sections</h2>
                <div class="law-sections-grid law-sections-grid-v2">
                    @foreach (var lawItem in itActSections)
                    {
                        <div class="law-section-card law-section-card-v2" @onclick="() => ViewLawDetails(lawItem)">
                            <div class="law-card-header law-card-header-v2">
                                <div class="section-number section-number-v2">
                                    <i class="bi bi-file-earmark-text"></i>
                                </div>
                                <div class="section-title-area section-title-area-v2">
                                    <h3>@lawItem.Title</h3>
                                    @if (lawItem.IsCybercrime)
                                    {
                                        <span class="cybercrime-badge cybercrime-badge-v2">
                                            <i class="bi bi-shield-exclamation"></i> Cybercrime
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="law-card-body law-card-body-v2">
                                <p>@lawItem.Content</p>
                            </div>
                            @if (!string.IsNullOrEmpty(lawItem.Punishment))
                            {
                                <div class="law-card-footer law-card-footer-v2">
                                    <div class="punishment-badge punishment-badge-v2">
                                        <i class="bi bi-exclamation-diamond"></i>
                                        <span>@lawItem.Punishment</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Case Precedents for Cybercrime -->
            <div class="precedents-section precedents-section-v2">
                <h2 class="section-title-v2"><i class="bi bi-book"></i> Cybercrime Case Precedents</h2>
                <p class="section-description section-description-v2">Notable judgments and precedents for cybercrime cases</p>
                <button class="btn-secondary btn-secondary-v2" @onclick='() => NavigateTo("/precedents")'>
                    <i class="bi bi-arrow-right-circle"></i> View All Precedents
                </button>
            </div>

            <!-- Legal Resources -->
            <div class="resources-section resources-section-v2">
                <h2 class="section-title-v2"><i class="bi bi-folder"></i> Legal Resources</h2>
                <div class="resource-grid resource-grid-v2">
                    @foreach (var resource in legalResources)
                    {
                        <div class="resource-card resource-card-v2 emergency">
                            <div class="resource-icon resource-icon-v2">
                                <i class="@resource.IconClass"></i>
                            </div>
                            <h3 class="resource-title-v2">@resource.Title</h3>
                            <p class="resource-description-v2">@resource.Description</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else if (currentUser.Role == UserRole.Police)
    {
        <div class="police-view police-view-v2">
            <div class="page-header role-header-v2">
                <div class="header-content header-content-v2">
                    <div class="header-icon header-icon-v2 police-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <div class="header-text header-text-v2">
                        <h1>Investigation Dashboard</h1>
                        <p class="header-subtitle header-subtitle-v2">Manage & Track Cybercrime Investigations</p>
                    </div>
                </div>
            </div>

            <!-- Statistics Dashboard - Fixed Grid -->
            @if (isLoading)
            {
                <div class="skeleton-stats-grid skeleton-stats-grid-v2" role="status" aria-label="Loading statistics">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="skeleton-stat-card skeleton-stat-card-v2">
                            <div class="skeleton-stat-icon skeleton-stat-icon-v2"></div>
                            <div class="skeleton-stat-content skeleton-stat-content-v2">
                                <div class="skeleton-stat-value skeleton-stat-value-v2"></div>
                                <div class="skeleton-stat-label skeleton-stat-label-v2"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="stats-grid-fixed stats-grid-v2">
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-file-text"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@statistics.TotalReports</h3>
                            <p>Total Reports</p>
                        </div>
                    </div>
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-hourglass-split"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@assignedReports.Count(r => r.Status == ReportStatus.UnderReview)</h3>
                            <p>Pending Review</p>
                        </div>
                    </div>
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-search"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@statistics.ActiveInvestigations</h3>
                            <p>Active Investigations</p>
                        </div>
                    </div>
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-file-earmark-check"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@statistics.FIRsFiled</h3>
                            <p>FIRs Filed</p>
                        </div>
                    </div>
                    <div class="stat-card-fixed stat-card-v2">
                        <div class="stat-icon-fixed stat-icon-v2">
                            <i class="bi bi-check-circle"></i>
                        </div>
                        <div class="stat-content-fixed stat-content-v2">
                            <h3>@statistics.CasesClosed</h3>
                            <p>Cases Closed</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Filter and Search -->
            <div class="filter-bar filter-bar-v2 enhanced-filter-bar">
                <div class="search-box search-box-v2">
                    <i class="bi bi-search"></i>
                    <input type="text" class="search-input-v2" @bind="searchTerm" @bind:event="oninput" @onkeyup="PerformSearch" 
                           placeholder="Search by report number, name, or details..." 
                           aria-label="Search reports by report number, name, or details" />
                </div>
                <select class="filter-select-v2" @bind="filterStatus" @bind:after="ApplyFilters" aria-label="Filter by status">
                    <option value="">All Status</option>
                    @foreach (ReportStatus status in Enum.GetValues(typeof(ReportStatus)))
                    {
                        <option value="@status">@status.ToString().Replace("_", " ")</option>
                    }
                </select>
                <select class="filter-select-v2" @bind="filterType" @bind:after="ApplyFilters" aria-label="Filter by cybercrime type">
                    <option value="">All Types</option>
                    @foreach (CybercrimeType type in Enum.GetValues(typeof(CybercrimeType)))
                    {
                        <option value="@type">@GetCrimeTypeName(type)</option>
                    }
                </select>
                <select class="filter-select-v2" @bind="sortColumn" @bind:after="ApplySorting" aria-label="Sort reports by">
                    <option value="date">Sort by Date</option>
                    <option value="status">Sort by Status</option>
                    <option value="type">Sort by Type</option>
                    <option value="urgent">Sort by Urgency</option>
                </select>
            </div>

            <!-- Reports List - Fixed Grid -->
            <div class="reports-container reports-container-v2">
                @if (isLoading)
                {
                    <div class="skeleton-reports-grid skeleton-reports-grid-v2" role="status" aria-label="Loading reports">
                        @for (int i = 0; i < 6; i++)
                        {
                            <div class="skeleton-report-card skeleton-report-card-v2">
                                <div class="skeleton-report-header skeleton-report-header-v2"></div>
                                <div class="skeleton-report-title skeleton-report-title-v2"></div>
                                <div class="skeleton-report-text skeleton-report-text-v2"></div>
                                <div class="skeleton-report-meta skeleton-report-meta-v2">
                                    <div class="skeleton-meta-item skeleton-meta-item-v2"></div>
                                    <div class="skeleton-meta-item skeleton-meta-item-v2"></div>
                                    <div class="skeleton-meta-item skeleton-meta-item-v2"></div>
                                </div>
                                <div class="skeleton-report-status skeleton-report-status-v2"></div>
                            </div>
                        }
                    </div>
                }
                else if (filteredReports.Any())
                {
                    <div class="reports-grid reports-grid-v2">
                        @foreach (var report in filteredReports)
                        {
                            <div class="report-card-fixed report-card-v2 @(report.IsUrgent ? "urgent" : "")" 
                                 @onclick="() => ViewReportDetails(report)"
                                 @onkeydown="@((e) => HandleKeyPress(e, () => ViewReportDetails(report)))"
                                 tabindex="0"
                                 role="article"
                                 aria-label="@($"Cybercrime report {report.ReportNumber}: {report.Title}")">
                                <div class="report-header-fixed report-card-header-v2">
                                    <div class="report-number-badge report-number-badge-v2">
                                        <i class="bi bi-file-earmark-text"></i>
                                        <span>@report.ReportNumber</span>
                                    </div>
                                    @if (report.IsUrgent)
                                    {
                                        <span class="urgent-badge urgent-badge-v2" aria-label="Urgent report">
                                            <i class="bi bi-exclamation-triangle-fill"></i>
                                        </span>
                                    }
                                </div>
                                
                                <div class="report-card-body report-card-body-v2">
                                    <h3 class="report-title-v2">@report.Title</h3>
                                    <p class="report-description-v2">@report.Description</p>
                                    
                                    <div class="report-meta-grid report-meta-grid-v2">
                                        <div class="meta-item report-meta-item-v2">
                                            <i class="bi bi-calendar3"></i>
                                            <span>@report.ReportedDate.ToString("MMM dd, yyyy")</span>
                                        </div>
                                        <div class="meta-item report-meta-item-v2">
                                            <i class="bi bi-tag"></i>
                                            <span>@GetCrimeTypeName(report.IncidentType)</span>
                                        </div>
                                        <div class="meta-item report-meta-item-v2">
                                            <i class="bi bi-person"></i>
                                            <span>@report.VictimName</span>
                                        </div>
                                        @if (report.FinancialLoss.HasValue)
                                        {
                                            <div class="meta-item report-meta-item-v2 loss">
                                                <i class="bi bi-currency-rupee"></i>
                                                <span>₹@report.FinancialLoss.Value.ToString("N0")</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                                
                                <div class="report-card-footer report-card-footer-v2">
                                    <span class="status-badge-fixed status-badge-v2 status-@report.Status.ToString().ToLower()">
                                        @report.Status.ToString().Replace("_", " ")
                                    </span>
                                    @if (!string.IsNullOrEmpty(report.FIRNumber))
                                    {
                                        <span class="fir-badge-fixed fir-badge-v2">
                                            <i class="bi bi-file-earmark-check-fill"></i> @report.FIRNumber
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state empty-state-v2">
                        <i class="bi bi-inbox"></i>
                        <p>No reports found matching your filters</p>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Report Details Modal - Enhanced Glassmorphic -->
    @if (selectedReport != null)
    {
        <div class="modal-overlay-glass modal-overlay-v2" @onclick="CloseModal">
            <div class="report-modal report-detail-modal-v2" @onclick:stopPropagation="true">
                <button class="report-close-btn modal-close-btn-v2" @onclick="CloseModal">
                    <i class="bi bi-x-lg"></i>
                </button>
                
                <div class="report-modal-header modal-header-v2">
                    <div class="report-title-section modal-title-section-v2">
                        @if (isEditingReport && (currentUser?.Role == UserRole.Police || currentUser?.Role == UserRole.Admin))
                        {
                            <select class="form-control form-select-v2 status-select" @bind="selectedReport.Status">
                                <option value="@ReportStatus.Submitted">Submitted</option>
                                <option value="@ReportStatus.UnderReview">Under Review</option>
                                <option value="@ReportStatus.InvestigationStarted">Investigation Started</option>
                                <option value="@ReportStatus.EvidenceCollected">Evidence Collected</option>
                                <option value="@ReportStatus.FIRFiled">FIR Filed</option>
                                <option value="@ReportStatus.Closed">Closed</option>
                            </select>
                        }
                        else
                        {
                            <div class="report-status-badge status-badge-v2 status-@selectedReport.Status.ToString().ToLower()">
                                @selectedReport.Status.ToString().Replace("_", " ")
