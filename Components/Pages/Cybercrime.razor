    private async Task ExportReports(string format)
    {
        isExporting = true;
        showExportMenu = false;
        
        try
        {
            if (format == "csv")
            {
                await ExportToCsv();
            }
            else if (format == "pdf")
            {
                await ExportToPdf();
            }
            else if (format == "json")
            {
                await ExportToJson();
            }
            
            ShowToast($"Reports exported successfully as {format.ToUpper()}!");
        }
        catch (Exception ex)
        {
            ShowToast($"Export failed: {ex.Message}");
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task ExportToCsv()
    {
        var csv = "Report Number,Title,Type,Status,Victim Name,Date,Financial Loss,FIR Number\n";
        foreach (var report in filteredReports)
        {
            csv += $"\"{report.ReportNumber}\",\"{report.Title}\",\"{GetCrimeTypeName(report.IncidentType)}\",\"{report.Status}\",\"{report.VictimName}\",\"{report.ReportedDate:yyyy-MM-dd}\",\"{report.FinancialLoss}\",\"{report.FIRNumber}\"\n";
        }
        
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);
        await JSRuntime.InvokeVoidAsync("downloadFile", "cybercrime-reports.csv", "data:text/csv;base64," + base64);
    }

    private async Task ExportToPdf()
    {
        var html = "<html><head><style>" +
            "body { font-family: Arial, sans-serif; } " +
            "table { width: 100%; border-collapse: collapse; } " +
            "th, td { border: 1px solid #ddd; padding: 8px; text-align: left; } " +
            "th { background-color: #4CAF50; color: white; } " +
            ".urgent { background-color: #ffebee; }" +
            "</style></head><body>" +
            "<h1>Cybercrime Reports</h1>" +
            "<p>Generated: " + DateTime.Now.ToString("MMMM dd, yyyy") + "</p>" +
            "<table><tr>" +
            "<th>Report #</th>" +
            "<th>Title</th>" +
            "<th>Type</th>" +
            "<th>Status</th>" +
            "<th>Date</th>" +
            "<th>Financial Loss</th>" +
            "</tr>";

        foreach (var report in filteredReports)
        {
            var rowClass = report.IsUrgent ? " class=\"urgent\"" : "";
            html += "<tr" + rowClass + ">" +
                "<td>" + report.ReportNumber + "</td>" +
                "<td>" + report.Title + "</td>" +
                "<td>" + GetCrimeTypeName(report.IncidentType) + "</td>" +
                "<td>" + report.Status.ToString().Replace("_", " ") + "</td>" +
                "<td>" + report.ReportedDate.ToString("MMM dd, yyyy") + "</td>" +
                "<td>" + (report.FinancialLoss.HasValue ? "₹" + report.FinancialLoss.Value.ToString("N0") : "N/A") + "</td>" +
                "</tr>";
        }

        html += "</table></body></html>";
        
        var bytes = System.Text.Encoding.UTF8.GetBytes(html);
        var base64 = Convert.ToBase64String(bytes);
        await JSRuntime.InvokeVoidAsync("downloadFile", "cybercrime-reports.html", "data:text/html;base64," + base64);
    }

    private async Task ExportToJson()
    {
        var reportData = filteredReports.Select(r => new
        {
            r.ReportNumber,
            r.Title,
            Type = GetCrimeTypeName(r.IncidentType),
            Status = r.Status.ToString(),
            r.VictimName,
            r.VictimEmail,
            r.VictimPhone,
            r.Description,
            ReportedDate = r.ReportedDate.ToString("yyyy-MM-dd"),
            r.FinancialLoss,
            r.FIRNumber,
            r.IsUrgent
        });
        
        var json = System.Text.Json.JsonSerializer.Serialize(reportData, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JSRuntime.InvokeVoidAsync("downloadFile", "cybercrime-reports.json", "data:application/json;base64," + base64);
    }

    private async Task PrintReports()
    {
        isPrinting = true;
        await JSRuntime.InvokeVoidAsync("window.print");
