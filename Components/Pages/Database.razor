    // Export and UI methods
    private void ToggleExportMenu()
    {
        showExportMenu = !showExportMenu;
    }

    private async Task ExportToCsv()
    {
        if (isExporting) return;
        
        try
        {
            isExporting = true;
            showExportMenu = false;

            var resourcesToExport = filteredResources.Any() ? filteredResources : allResources;
            var csv = new System.Text.StringBuilder();
            csv.AppendLine("Title,Type,Category,Author,Published Date,Views,Downloads");

            foreach (var resource in resourcesToExport)
            {
                csv.AppendLine($"\"{resource.Title}\",\"{resource.Type}\",\"{resource.Category}\",\"{resource.Author}\",\"{resource.PublishedDate:yyyy-MM-dd}\",{resource.Views},{resource.Downloads}");
            }

            var fileName = $"legal_database_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(csv.ToString()));
            var dataUrl = $"data:text/csv;base64,{base64}";

            await JS.InvokeVoidAsync("eval", $@"
                const link = document.createElement('a');
                link.href = '{dataUrl}';
                link.download = '{fileName}';
                link.click();
            ");

            ShowToast($"Exported {resourcesToExport.Count} resources to CSV successfully!");
        }
        catch (Exception ex)
        {
            ShowToast($"Export failed: {ex.Message}");
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task ExportToPdf()
    {
        if (isExporting) return;
        
        try
        {
            isExporting = true;
            showExportMenu = false;

            var resourcesToExport = filteredResources.Any() ? filteredResources : allResources;
            var tableRows = string.Join("", resourcesToExport.Select(r => $@"
                <tr>
                    <td>{r.Title}</td>
                    <td>{r.Type}</td>
                    <td>{r.Category}</td>
                    <td>{r.PublishedDate:MMM dd, yyyy}</td>
                    <td>{r.Views}</td>
                </tr>"));

            var html = $@"
                <!DOCTYPE html>
                <html>
                <head>
                    <meta charset='utf-8'>
                    <title>Legal Database - {DateTime.Now:MMMM dd, yyyy}</title>
                    <style>
                        body {{ font-family: 'Segoe UI', Arial, sans-serif; padding: 20px; }}
                        .header {{ border-bottom: 2px solid #0066cc; margin-bottom: 20px; padding-bottom: 10px; }}
                        .header h1 {{ color: #0066cc; margin: 0; }}
                        .meta {{ color: #666; font-size: 14px; margin-top: 5px; }}
                        table {{ width: 100%; border-collapse: collapse; margin-top: 20px; }}
                        th, td {{ padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }}
                        th {{ background-color: #f5f5f5; font-weight: 600; }}
                        tr:hover {{ background-color: #f9f9f9; }}
                    </style>
                </head>
                <body>
                    <div class='header'>
                        <h1>Legal Database Resources</h1>
                        <div class='meta'>
                            Generated: {DateTime.Now:MMMM dd, yyyy HH:mm} | 
                            Category: {activeCategory} | 
                            Total: {resourcesToExport.Count} resources
                        </div>
                    </div>
                    <table>
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Type</th>
                                <th>Category</th>
                                <th>Published</th>
                                <th>Views</th>
                            </tr>
                        </thead>
                        <tbody>
                            {tableRows}
                        </tbody>
                    </table>
                </body>
                </html>
            ";

            var fileName = $"legal_database_{DateTime.Now:yyyyMMdd_HHmmss}.html";
            var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(html));
            var dataUrl = $"data:text/html;base64,{base64}";

            await JS.InvokeVoidAsync("eval", $@"
                const link = document.createElement('a');
                link.href = '{dataUrl}';
                link.download = '{fileName}';
                link.click();
            ");

            ShowToast("Database exported to PDF/HTML successfully!");
        }
        catch (Exception ex)
        {
            ShowToast($"Export failed: {ex.Message}");
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task ExportToJson()
    {
        if (isExporting) return;
        
        try
        {
            isExporting = true;
            showExportMenu = false;

            var resourcesToExport = filteredResources.Any() ? filteredResources : allResources;
            var data = new
            {
                exportedAt = DateTime.Now,
                category = activeCategory,
                totalResources = resourcesToExport.Count,
                resources = resourcesToExport.Select(r => new
                {
                    r.Id,
                    r.Title,
                    r.Description,
                    r.Type,
                    r.Category,
                    r.Author,
                    publishedDate = r.PublishedDate.ToString("yyyy-MM-dd"),
                    r.Tags,
                    r.Views,
                    r.Downloads
                })
            };

            var json = System.Text.Json.JsonSerializer.Serialize(data, new System.Text.Json.JsonSerializerOptions 
            { 
                WriteIndented = true 
            });

            var fileName = $"legal_database_{DateTime.Now:yyyyMMdd_HHmmss}.json";
            var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(json));
            var dataUrl = $"data:application/json;base64,{base64}";

            await JS.InvokeVoidAsync("eval", $@"
                const link = document.createElement('a');
                link.href = '{dataUrl}';
                link.download = '{fileName}';
                link.click();
            ");

            ShowToast("Database exported to JSON successfully!");
        }
        catch (Exception ex)
        {
            ShowToast($"Export failed: {ex.Message}");
        }
        finally
        {
            isExporting = false;
        }
    }

