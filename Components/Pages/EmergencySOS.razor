        }
    }

    private void OpenAddContactModal()
    {
        newContact = new EmergencyContact();
        showAddContactModal = true;
    }

    private void CloseAddContactModal()
    {
        showAddContactModal = false;
    }

    private void SaveContact()
    {
        if (!string.IsNullOrWhiteSpace(newContact.Name) && !string.IsNullOrWhiteSpace(newContact.Phone))
        {
            newContact.Id = emergencyContacts.Count > 0 ? emergencyContacts.Max(c => c.Id) + 1 : 1;
            emergencyContacts.Add(newContact);
            CloseAddContactModal();
        }
    }

    private void RemoveContact(EmergencyContact contact)
    {
        emergencyContacts.Remove(contact);
    }

