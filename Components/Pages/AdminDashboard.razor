    private async Task ExportToCsv()
    {
        isExporting = true;
        showExportMenu = false;
        StateHasChanged();

        try
        {
            var csv = new System.Text.StringBuilder();
            csv.AppendLine("Name,Email,Phone,Role,Status,Verification Date");

            foreach (var user in GetFilteredUsers())
            {
                csv.AppendLine($"\"{user.Name}\",\"{user.Email}\",\"{user.Phone}\",\"{user.Role}\",\"{user.VerificationStatus}\",\"{user.VerifiedAt?.ToString("yyyy-MM-dd") ?? "N/A"}\"");
            }

            var data = System.Text.Encoding.UTF8.GetBytes(csv.ToString());
            var base64 = Convert.ToBase64String(data);
            var url = $"data:text/csv;base64,{base64}";

            await JS.InvokeVoidAsync("eval", $@"
                var link = document.createElement('a');
                link.href = '{url}';
                link.download = 'admin-dashboard-{DateTime.Now:yyyyMMdd}.csv';
                link.click();
            ");

            ShowToast($"Exported {GetFilteredUsers().Count} users to CSV successfully!");
        }
        finally
        {
            isExporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportToPdf()
    {
        isExporting = true;
        showExportMenu = false;
        StateHasChanged();

        try
        {
            var html = $@"
                <!DOCTYPE html>
                <html>
                <head>
                    <meta charset='utf-8'>
                    <title>Admin Dashboard Report</title>
                    <style>
                        body {{ font-family: 'Segoe UI', Arial, sans-serif; padding: 20px; }}
                        h1 {{ color: #333; border-bottom: 2px solid #667eea; padding-bottom: 10px; }}
                        .meta {{ color: #666; margin-bottom: 20px; }}
                        .stats {{ display: flex; gap: 20px; margin: 20px 0; }}
                        .stat {{ padding: 15px; border-radius: 8px; flex: 1; text-align: center; }}
                        .stat.pending {{ background: #fff3e0; color: #ff9800; }}
                        .stat.verified {{ background: #e8f5e9; color: #4caf50; }}
                        .stat.rejected {{ background: #ffebee; color: #f44336; }}
                        .stat.total {{ background: #e3f2fd; color: #2196f3; }}
                        .stat-value {{ font-size: 32px; font-weight: bold; }}
                        .stat-label {{ font-size: 14px; margin-top: 5px; }}
                        table {{ width: 100%; border-collapse: collapse; margin-top: 20px; }}
                        th, td {{ border: 1px solid #ddd; padding: 12px; text-align: left; }}
                        th {{ background-color: #667eea; color: white; }}
                        tr:nth-child(even) {{ background-color: #f5f5f5; }}
                    </style>
                </head>
                <body>
                    <h1>Admin Dashboard Report</h1>
                    <div class='meta'>
                        Generated on {DateTime.Now:MMMM dd, yyyy hh:mm tt}<br>
                        Total Users: {totalUsers} | Pending: {pendingCount} | Verified: {verifiedCount} | Rejected: {rejectedCount}
                    </div>
                    
                    <div class='stats'>
                        <div class='stat pending'>
                            <div class='stat-value'>{pendingCount}</div>
                            <div class='stat-label'>Pending Review</div>
                        </div>
                        <div class='stat verified'>
                            <div class='stat-value'>{verifiedCount}</div>
                            <div class='stat-label'>Verified</div>
                        </div>
                        <div class='stat rejected'>
                            <div class='stat-value'>{rejectedCount}</div>
                            <div class='stat-label'>Rejected</div>
                        </div>
                        <div class='stat total'>
                            <div class='stat-value'>{totalUsers}</div>
                            <div class='stat-label'>Total Users</div>
                        </div>
                    </div>
                    
                    <table>
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Verification Date</th>
                            </tr>
                        </thead>
                        <tbody>";

            foreach (var user in GetFilteredUsers())
            {
                var verifiedDate = user.VerifiedAt?.ToString("yyyy-MM-dd") ?? "N/A";
                html += $@"
                            <tr>
                                <td>{user.Name}</td>
                                <td>{user.Email}</td>
                                <td>{user.Role}</td>
                                <td>{user.VerificationStatus}</td>
                                <td>{verifiedDate}</td>
                            </tr>";
            }

            html += @"
                        </tbody>
                    </table>
                </body>
                </html>";

            var data = System.Text.Encoding.UTF8.GetBytes(html);
            var base64 = Convert.ToBase64String(data);
            var url = $"data:text/html;base64,{base64}";

            await JS.InvokeVoidAsync("eval", $@"
                var link = document.createElement('a');
                link.href = '{url}';
                link.download = 'admin-dashboard-{DateTime.Now:yyyyMMdd}.html';
                link.click();
            ");

            ShowToast($"Exported dashboard report to PDF/HTML successfully!");
        }
        finally
        {
            isExporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportToJson()
    {
        isExporting = true;
        showExportMenu = false;
        StateHasChanged();

        try
        {
            var exportData = new
            {
                exportedAt = DateTime.Now,
                statistics = new
                {
                    pendingCount,
                    verifiedCount,
                    rejectedCount,
                    totalUsers
                },
                users = GetFilteredUsers().Select(u => new
                {
                    u.Id,
                    u.Name,
                    u.Email,
                    u.Phone,
                    Role = u.Role.ToString(),
                    Status = u.VerificationStatus.ToString(),
                    VerifiedAt = u.VerifiedAt?.ToString("yyyy-MM-dd"),
                    BarCouncilNumber = u.BarCouncilNumber,
                    PoliceId = u.PoliceId
                })
            };

            var json = System.Text.Json.JsonSerializer.Serialize(exportData, new System.Text.Json.JsonSerializerOptions
            {
                WriteIndented = true
            });

            var data = System.Text.Encoding.UTF8.GetBytes(json);
            var base64 = Convert.ToBase64String(data);
            var url = $"data:application/json;base64,{base64}";

            await JS.InvokeVoidAsync("eval", $@"
                var link = document.createElement('a');
                link.href = '{url}';
                link.download = 'admin-dashboard-{DateTime.Now:yyyyMMdd}.json';
                link.click();
            ");

            ShowToast($"Exported {GetFilteredUsers().Count} users to JSON successfully!");
        }
        finally
        {
            isExporting = false;
            StateHasChanged();
        }
    }

