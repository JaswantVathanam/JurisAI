    // Toast Notification Methods
    private void ShowToast(string message)
    {
        toastMessage = message;
        showToast = true;
        StateHasChanged();

        toastTimer?.Dispose();
        toastTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                HideToast();
            });
        }, null, 3000, System.Threading.Timeout.Infinite);
    }

    private void HideToast()
    {
        toastTimer?.Dispose();
        showToast = false;
        StateHasChanged();
    }

