@page "/admin"
@using AILegalAsst.Models
@using AILegalAsst.Services
@using AILegalAsst.Components.Shared
@inject AuthenticationService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Admin Dashboard - JurisAI</PageTitle>

<link rel="stylesheet" href="admin-dashboard.css" />
<link rel="stylesheet" href="admindashboard-enhancements.css" />
<link rel="stylesheet" href="admindashboard-print.css" media="print" />

<CustomErrorBoundary ShowDetails="true" ShowReportButton="true">

    <!-- Print-Only Header -->
    <div class="print-only print-header-v2">
        <div class="print-title-v2"><i class="bi bi-shield-lock-fill"></i> Admin Dashboard Report</div>
        <div class="print-meta-v2">
            Generated: @DateTime.Now.ToString("MMMM dd, yyyy hh:mm tt")
        </div>
        <div class="print-stats-v2">
            <div class="print-stat-item-v2"><strong>Total Users:</strong> @totalUsers</div>
            <div class="print-stat-item-v2"><strong>Pending:</strong> @pendingCount</div>
            <div class="print-stat-item-v2"><strong>Verified:</strong> @verifiedCount</div>
            <div class="print-stat-item-v2"><strong>Rejected:</strong> @rejectedCount</div>
        </div>
    </div>

    @if (currentUser?.Role != UserRole.Admin)
    {
        <div class="error-container-v2">
            <i class="bi bi-shield-exclamation"></i>
            <h2>Access Denied</h2>
            <p>You do not have permission to access this page.</p>
            <button class="btn-home-v2" @onclick="GoToHome"><i class="bi bi-house"></i> Go to Home</button>
        </div>
    }
    else
    {
        <div class="admin-dashboard-v2">
            <div class="dashboard-container-v2">
            <!-- Header -->
            <div class="admin-header-v2">
                <div class="header-content-v2">
                    <h1><i class="bi bi-shield-lock-fill"></i> Admin Verification Center</h1>
                    <p class="header-subtitle-v2">Manage and verify Lawyer & Police registrations</p>
                </div>
                <div class="header-actions-v2">
                    <button class="btn-print-v2" @onclick="PrintDashboard" disabled="@isPrinting" 
                            aria-label="Print dashboard report">
                        @if (isPrinting)
                        {
                            <span class="spinner-small"></span>
                        }
                        else
                        {
                            <i class="bi bi-printer"></i>
                        }
                        <span>Print Report</span>
                    </button>
                    <div class="export-dropdown-v2">
                        <button class="btn-export-v2" @onclick="ToggleExportMenu" disabled="@isExporting"
                                aria-label="Export dashboard data" aria-expanded="@showExportMenu">
                            @if (isExporting)
                            {
                                <span class="spinner-small"></span>
                            }
                            else
                            {
                                <i class="bi bi-download"></i>
                            }
                            <span>Export Data</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>
                        @if (showExportMenu)
                        {
                            <div class="export-menu-v2" role="menu">
                                <button class="export-option-v2" @onclick="ExportToCsv" role="menuitem">
                                    <i class="bi bi-filetype-csv"></i>
                                    <span>Export as CSV</span>
                                </button>
                                <button class="export-option-v2" @onclick="ExportToPdf" role="menuitem">
                                    <i class="bi bi-file-pdf"></i>
                                    <span>Export as PDF</span>
                                </button>
                                <button class="export-option-v2" @onclick="ExportToJson" role="menuitem">
                                    <i class="bi bi-filetype-json"></i>
                                    <span>Export as JSON</span>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Statistics Cards -->
            <div class="stats-grid-v2">
                @if (isLoading)
                {
                    <!-- Skeleton Loading for Statistics -->
                    <div class="skeleton-stat-card-v2">
                        <div class="skeleton-icon-v2"></div>
                        <div class="skeleton-value-v2"></div>
                        <div class="skeleton-label-v2"></div>
                    </div>
                    <div class="skeleton-stat-card-v2">
                        <div class="skeleton-icon-v2"></div>
                        <div class="skeleton-value-v2"></div>
                        <div class="skeleton-label-v2"></div>
                    </div>
                    <div class="skeleton-stat-card-v2">
                        <div class="skeleton-icon-v2"></div>
                        <div class="skeleton-value-v2"></div>
                        <div class="skeleton-label-v2"></div>
                    </div>
                    <div class="skeleton-stat-card-v2">
                        <div class="skeleton-icon-v2"></div>
                        <div class="skeleton-value-v2"></div>
                        <div class="skeleton-label-v2"></div>
                    </div>
                }
                else
                {
                    <div class="stat-card-v2 pending">
                        <div class="stat-header-v2">
                            <div class="stat-icon-v2">
                                <i class="bi bi-clock-history"></i>
                            </div>
                        </div>
                        <div class="stat-value-v2">@pendingCount</div>
                        <div class="stat-label-v2">Pending Review</div>
                    </div>

                    <div class="stat-card-v2 verified">
                        <div class="stat-header-v2">
                            <div class="stat-icon-v2">
                                <i class="bi bi-check-circle-fill"></i>
                            </div>
                        </div>
                        <div class="stat-value-v2">@verifiedCount</div>
                        <div class="stat-label-v2">Verified</div>
                    </div>

                    <div class="stat-card-v2 rejected">
                        <div class="stat-header-v2">
                            <div class="stat-icon-v2">
                                <i class="bi bi-x-circle-fill"></i>
                            </div>
                        </div>
                        <div class="stat-value-v2">@rejectedCount</div>
                        <div class="stat-label-v2">Rejected</div>
                    </div>

                    <div class="stat-card-v2 total">
                        <div class="stat-header-v2">
                            <div class="stat-icon-v2">
                                <i class="bi bi-people-fill"></i>
                            </div>
                        </div>
                        <div class="stat-value-v2">@totalUsers</div>
                        <div class="stat-label-v2">Total Users</div>
                    </div>
                }
            </div>

            <!-- Filters -->
            <div class="filter-bar-v2">
                <div class="filter-group-v2">
                    <label class="filter-label-v2" for="role-filter">Role:</label>
                    <select id="role-filter" @bind="filterRole" class="filter-select-v2" 
                            aria-label="Filter by user role">
                        <option value="All">All Roles</option>
                        <option value="Lawyer">Lawyer Only</option>
                        <option value="Police">Police Only</option>
                    </select>
                </div>

                <div class="filter-group-v2">
                    <label class="filter-label-v2" for="status-filter">Status:</label>
                    <select id="status-filter" @bind="filterStatus" class="filter-select-v2" 
                            aria-label="Filter by verification status">
                        <option value="All">All Statuses</option>
                        <option value="Pending">Pending</option>
                        <option value="UnderReview">Under Review</option>
                        <option value="MoreInfoNeeded">More Info Needed</option>
                    </select>
                </div>

                <div class="search-group-v2">
                    <i class="bi bi-search"></i>
                    <input type="search" class="search-input-v2" @bind="searchQuery" @bind:event="oninput" 
                           placeholder="Search by name, email, ID..." 
                           aria-label="Search users by name, email, or ID" />
                </div>
            </div>

            <!-- Pending Verifications List -->
            <div class="verifications-section-v2">
                @if (!GetFilteredUsers().Any())
                {
                    <div class="empty-state-v2">
                        <i class="bi bi-check-circle"></i>
                        <p>No pending verifications at the moment. All caught up!</p>
                    </div>
                }
                else
                {
                    <!-- Lawyers Section -->
                    @if (GetFilteredUsers().Any(u => u.Role == UserRole.Lawyer))
                    {
                        <div class="role-section-v2">
                            <div class="role-header-v2">
                                <i class="bi bi-briefcase"></i>
                                <h2>Lawyers</h2>
                                <span class="user-count-badge-v2">@GetFilteredUsers().Count(u => u.Role == UserRole.Lawyer) users</span>
                            </div>
                            <div class="users-grid-v2">
                                @foreach (var user in GetFilteredUsers().Where(u => u.Role == UserRole.Lawyer))
                                {
                                    <div class="user-card-v2">
                                        <div class="user-header-v2">
                                            <div class="user-avatar-v2">
                                                @user.Name.Substring(0, 1).ToUpper()
                                            </div>
                                            <div class="user-info-v2">
                                                <h4 class="user-name-v2">Adv. @user.Name</h4>
                                                <p class="user-email-v2">@user.Email</p>
                                            </div>
                                            <span class="status-badge-v2 @user.VerificationStatus.ToString().ToLower()">
                                                @user.VerificationStatus
                                            </span>
                                        </div>

                                        <div class="user-details-v2">
                                            <div class="detail-item-v2">
                                                <span class="detail-label-v2">Bar Council</span>
                                                <span class="detail-value-v2">@user.BarCouncilNumber</span>
                                            </div>
                                            <div class="detail-item-v2">
                                                <span class="detail-label-v2">State</span>
                                                <span class="detail-value-v2">@user.BarCouncilState</span>
                                            </div>
                                            <div class="detail-item-v2">
                                                <span class="detail-label-v2">Experience</span>
                                                <span class="detail-value-v2">@user.YearsOfPractice years</span>
                                            </div>
                                            <div class="detail-item-v2">
                                                <span class="detail-label-v2">Specialization</span>
                                                <span class="detail-value-v2">@(user.Specialization ?? "General")</span>
                                            </div>
                                        </div>

                                        <div class="user-actions-v2">
                                            <button class="btn-action-v2 btn-view-v2" @onclick="() => ViewUser(user)">
                                                <i class="bi bi-eye"></i> View
                                            </button>
                                            <button class="btn-action-v2 btn-approve-v2" @onclick="() => ApproveUser(user)">
                                                <i class="bi bi-check-lg"></i> Approve
                                            </button>
                                            <button class="btn-action-v2 btn-reject-v2" @onclick="() => ShowRejectModal(user)">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Police Section -->
                    @if (GetFilteredUsers().Any(u => u.Role == UserRole.Police))
                    {
                        <div class="role-section-v2">
                            <div class="role-header-v2">
                                <i class="bi bi-shield-fill-check"></i>
                                <h2>Police Officers</h2>
                                <span class="user-count-badge-v2">@GetFilteredUsers().Count(u => u.Role == UserRole.Police) users</span>
                            </div>
                            <div class="users-grid-v2">
                                @foreach (var user in GetFilteredUsers().Where(u => u.Role == UserRole.Police))
                                {
                                    <div class="user-card-v2">
                                        <div class="user-header-v2">
                                            <div class="user-avatar-v2">
                                                @user.Name.Substring(0, 1).ToUpper()
                                            </div>
                                            <div class="user-info-v2">
                                                <h4 class="user-name-v2">@user.Rank @user.Name</h4>
                                                <p class="user-email-v2">@user.Email</p>
                                            </div>
                                            <span class="status-badge-v2 @user.VerificationStatus.ToString().ToLower()">
                                                @user.VerificationStatus
                                            </span>
                                        </div>

                                        <div class="user-details-v2">
                                            <div class="detail-item-v2">
                                                <span class="detail-label-v2">Police ID</span>
                                                <span class="detail-value-v2">@user.PoliceId</span>
                                            </div>
                                            <div class="detail-item-v2">
                                                <span class="detail-label-v2">Department</span>
                                                <span class="detail-value-v2">@user.Department</span>
                                            </div>
                                            <div class="detail-item-v2">
                                                <span class="detail-label-v2">Station</span>
                                                <span class="detail-value-v2">@user.PoliceStation</span>
                                            </div>
                                            <div class="detail-item-v2">
                                                <span class="detail-label-v2">Jurisdiction</span>
                                                <span class="detail-value-v2">@(user.Jurisdiction ?? "N/A")</span>
                                            </div>
                                        </div>

                                        <div class="user-actions-v2">
                                            <button class="btn-action-v2 btn-view-v2" @onclick="() => ViewUser(user)">
                                                <i class="bi bi-eye"></i> View
                                            </button>
                                            <button class="btn-action-v2 btn-approve-v2" @onclick="() => ApproveUser(user)">
                                                <i class="bi bi-check-lg"></i> Approve
                                            </button>
                                            <button class="btn-action-v2 btn-reject-v2" @onclick="() => ShowRejectModal(user)">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Verification Modal -->
            @if (showViewModal && selectedUser != null)
            {
                <div class="modal-backdrop-v2" @onclick="CloseModal">
                    <div class="modal-content-v2" @onclick:stopPropagation="true">
                        <div class="modal-header-v2">
                            <h2>
                                <i class="bi bi-@(selectedUser.Role == UserRole.Lawyer ? "briefcase" : "shield-fill")"></i>
                                Verification Review - @selectedUser.Name
                            </h2>
                            <button class="btn-close-v2" @onclick="CloseModal">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>

                        <div class="modal-body-v2">
                            <!-- Personal Information -->
                            <div class="info-section-v2">
                                <h3><i class="bi bi-person"></i> Personal Information</h3>
                                <div class="info-grid-v2">
                                    <div class="info-item-v2">
                                        <label>Full Name</label>
                                        <span>@selectedUser.Name</span>
                                    </div>
                                    <div class="info-item-v2">
                                        <label>Email</label>
                                        <span>@selectedUser.Email</span>
                                    </div>
                                    <div class="info-item-v2">
                                        <label>Phone</label>
                                        <span>@selectedUser.Phone</span>
                                    </div>
                                    <div class="info-item-v2">
                                        <label>Status</label>
                                        <span class="status-badge-v2 @selectedUser.VerificationStatus.ToString().ToLower()">
                                            @selectedUser.VerificationStatus
                                        </span>
                                    </div>
                                </div>
                            </div>

                            @if (selectedUser.Role == UserRole.Lawyer)
                            {
                                <!-- Lawyer Professional Details -->
                                <div class="info-section-v2">
                                    <h3><i class="bi bi-briefcase"></i> Professional Details</h3>
                                    <div class="info-grid-v2">
                                        <div class="info-item-v2">
                                            <label>Bar Council Number</label>
                                            <span>@selectedUser.BarCouncilNumber</span>
                                        </div>
                                        <div class="info-item-v2">
                                            <label>State</label>
                                            <span>@selectedUser.BarCouncilState</span>
                                        </div>
                                        <div class="info-item-v2">
                                            <label>Years of Practice</label>
                                            <span>@selectedUser.YearsOfPractice years</span>
                                        </div>
                                        <div class="info-item-v2">
                                            <label>Specialization</label>
                                            <span>@selectedUser.Specialization</span>
                                        </div>
                                        <div class="info-item-v2 full-width">
                                            <label>Office Address</label>
                                            <span>@selectedUser.OfficeAddress</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Documents -->
                                <div class="info-section-v2">
                                    <h3><i class="bi bi-file-earmark-pdf"></i> Documents</h3>
                                    <div class="document-list-v2">
                                        <div class="document-item-v2">
                                            <i class="bi bi-file-pdf"></i>
                                            <span>Bar Council Certificate</span>
                                            <button class="btn-doc-v2" @onclick="() => ViewDocument(selectedUser.BarCouncilCertificate)">
                                                <i class="bi bi-eye"></i> View
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                            else if (selectedUser.Role == UserRole.Police)
                            {
                                <!-- Police Service Details -->
                                <div class="info-section-v2">
                                    <h3><i class="bi bi-shield-fill"></i> Service Details</h3>
                                    <div class="info-grid-v2">
                                        <div class="info-item-v2">
                                            <label>Police ID</label>
                                            <span>@selectedUser.PoliceId</span>
                                        </div>
                                        <div class="info-item-v2">
                                            <label>Rank</label>
                                            <span>@selectedUser.Rank</span>
                                        </div>
                                        <div class="info-item-v2">
                                            <label>Department</label>
                                            <span>@selectedUser.Department</span>
                                        </div>
                                        <div class="info-item-v2">
                                            <label>Police Station</label>
                                            <span>@selectedUser.PoliceStation</span>
                                        </div>
                                        <div class="info-item-v2 full-width">
                                            <label>Jurisdiction</label>
                                            <span>@selectedUser.Jurisdiction</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Documents -->
                                <div class="info-section-v2">
                                    <h3><i class="bi bi-file-earmark-pdf"></i> Documents</h3>
                                    <div class="document-list-v2">
                                        <div class="document-item-v2">
                                            <i class="bi bi-file-pdf"></i>
                                            <span>Service ID Card</span>
                                            <button class="btn-doc-v2" @onclick="() => ViewDocument(selectedUser.ServiceIdCard)">
                                                <i class="bi bi-eye"></i> View
                                            </button>
                                        </div>
                                        @if (!string.IsNullOrEmpty(selectedUser.AuthorizationLetter))
                                        {
                                            <div class="document-item-v2">
                                                <i class="bi bi-file-pdf"></i>
                                                <span>Authorization Letter</span>
                                                <button class="btn-doc-v2" @onclick="() => ViewDocument(selectedUser.AuthorizationLetter)">
                                                    <i class="bi bi-eye"></i> View
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- Admin Notes -->
                            <div class="info-section-v2">
                                <h3><i class="bi bi-pencil-square"></i> Admin Notes</h3>
                                <textarea @bind="adminNotes" class="admin-notes-input-v2" 
                                          placeholder="Add your verification notes here..." rows="4"></textarea>
                            </div>
                        </div>

                        <div class="modal-footer-v2">
                            <button class="btn-modal-v2 btn-approve-v2" @onclick="() => ApproveUser(selectedUser)">
                                <i class="bi bi-check-circle"></i> Approve & Verify
                            </button>
                            <button class="btn-modal-v2 btn-info-v2" @onclick="() => RequestMoreInfo(selectedUser)">
                                <i class="bi bi-envelope"></i> Request More Info
                            </button>
                            <button class="btn-modal-v2 btn-reject-v2" @onclick="() => ShowRejectModal(selectedUser)">
                                <i class="bi bi-x-circle"></i> Reject Application
                            </button>
                            <button class="btn-modal-v2 btn-cancel-v2" @onclick="CloseModal">
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            }

            <!-- Reject Modal -->
            @if (showRejectModal && selectedUser != null)
            {
                <div class="modal-backdrop-v2" @onclick="CloseRejectModal">
                    <div class="modal-content-v2 small" @onclick:stopPropagation="true">
                        <div class="modal-header-v2">
                            <h2><i class="bi bi-x-circle"></i> Reject Application</h2>
                            <button class="btn-close-v2" @onclick="CloseRejectModal">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>

                        <div class="modal-body-v2">
                            <p>You are about to reject <strong>@selectedUser.Name</strong>'s application.</p>
                            <p>Please provide a reason for rejection:</p>
                            <textarea @bind="rejectionReason" class="rejection-input-v2" 
                                      placeholder="Reason for rejection (required)..." rows="4" required></textarea>
                        </div>

                        <div class="modal-footer-v2">
                            <button class="btn-modal-v2 btn-reject-v2" @onclick="() => RejectUser(selectedUser)" 
                                    disabled="@string.IsNullOrWhiteSpace(rejectionReason)">
                                <i class="bi bi-x-circle"></i> Confirm Rejection
                            </button>
                            <button class="btn-modal-v2 btn-cancel-v2" @onclick="CloseRejectModal">
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            }

            <!-- Toast Notification -->
            @if (showToast)
            {
                <div class="toast-v2 success" role="alert" aria-live="polite">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@toastMessage</span>
                    <button class="toast-close-v2" @onclick="HideToast" aria-label="Close notification">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            }
            </div>
        </div>
    }

</CustomErrorBoundary>

@code {
    private User? currentUser;
    private List<User> allUsers = new();
    private string filterRole = "All";
    private string filterStatus = "Pending";
    private string searchQuery = string.Empty;
    
    private User? selectedUser;
    private bool showViewModal = false;
    private bool showRejectModal = false;
    private string adminNotes = string.Empty;
    private string rejectionReason = string.Empty;
    
    // Enhancement State Variables
    private bool isLoading = true;
    private bool isExporting = false;
    private bool isPrinting = false;
    private bool showExportMenu = false;
    private bool showToast = false;
    private string toastMessage = string.Empty;
    private System.Threading.Timer? toastTimer;

    // Statistics
    private int pendingCount = 0;
    private int verifiedCount = 0;
    private int rejectedCount = 0;
    private int totalUsers = 0;

    protected override async Task OnInitializedAsync()
    {
        currentUser = AuthService.GetCurrentUser();
        
        if (currentUser?.Role != UserRole.Admin)
        {
            return;
        }

        // Simulate loading delay
        await Task.Delay(500);
        
        LoadUsers();
        CalculateStatistics();
        
        isLoading = false;
    }

    private void LoadUsers()
    {
        // Get all users from authentication service
        allUsers = AuthService.GetAllUsers()
            .Where(u => u.Role == UserRole.Lawyer || u.Role == UserRole.Police)
            .ToList();
    }

    private void CalculateStatistics()
    {
        pendingCount = allUsers.Count(u => u.VerificationStatus == VerificationStatus.Pending || 
                                            u.VerificationStatus == VerificationStatus.UnderReview ||
                                            u.VerificationStatus == VerificationStatus.MoreInfoNeeded);
        verifiedCount = allUsers.Count(u => u.VerificationStatus == VerificationStatus.Verified);
        rejectedCount = allUsers.Count(u => u.VerificationStatus == VerificationStatus.Rejected);
        totalUsers = allUsers.Count;
    }

    private List<User> GetFilteredUsers()
    {
        var filtered = allUsers.AsEnumerable();

        // Filter by role
        if (filterRole != "All")
        {
            var role = Enum.Parse<UserRole>(filterRole);
            filtered = filtered.Where(u => u.Role == role);
        }

        // Filter by status
        if (filterStatus != "All")
        {
            var status = Enum.Parse<VerificationStatus>(filterStatus);
            filtered = filtered.Where(u => u.VerificationStatus == status);
        }
        else
        {
            // Default: show only pending statuses
            filtered = filtered.Where(u => u.VerificationStatus == VerificationStatus.Pending || 
                                          u.VerificationStatus == VerificationStatus.UnderReview ||
                                          u.VerificationStatus == VerificationStatus.MoreInfoNeeded);
        }

        // Search filter
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var query = searchQuery.ToLower();
            filtered = filtered.Where(u => 
                u.Name.ToLower().Contains(query) ||
                u.Email.ToLower().Contains(query) ||
                (u.BarCouncilNumber?.ToLower().Contains(query) ?? false) ||
                (u.PoliceId?.ToLower().Contains(query) ?? false)
            );
        }

        return filtered.ToList();
    }

    private void ViewUser(User user)
    {
        selectedUser = user;
        adminNotes = string.Empty;
        showViewModal = true;
    }

    private void ApproveUser(User user)
    {
        user.VerificationStatus = VerificationStatus.Verified;
        user.VerifiedAt = DateTime.Now;
        
        // Create verification log
        var log = new VerificationLog
        {
            UserId = user.Id,
            AdminId = currentUser!.Id,
            AdminName = currentUser.Name,
            OldStatus = VerificationStatus.Pending,
            NewStatus = VerificationStatus.Verified,
            AdminNotes = adminNotes,
            ActionDate = DateTime.Now,
            ActionType = "Approved"
        };

        // TODO: Save to database
        
        ShowToast($"{user.Name} has been successfully verified!");
        CloseModal();
        CalculateStatistics();
        StateHasChanged();
    }

    private void ShowRejectModal(User user)
    {
        selectedUser = user;
        rejectionReason = string.Empty;
        showRejectModal = true;
        showViewModal = false;
    }

    private void RejectUser(User user)
    {
        if (string.IsNullOrWhiteSpace(rejectionReason))
        {
            return;
        }

        user.VerificationStatus = VerificationStatus.Rejected;
        user.RejectionReason = rejectionReason;
        
        // Create verification log
        var log = new VerificationLog
        {
            UserId = user.Id,
            AdminId = currentUser!.Id,
            AdminName = currentUser.Name,
            OldStatus = VerificationStatus.Pending,
            NewStatus = VerificationStatus.Rejected,
            RejectionReason = rejectionReason,
            AdminNotes = adminNotes,
            ActionDate = DateTime.Now,
            ActionType = "Rejected"
        };

        // TODO: Save to database
        // TODO: Send email notification to user
        
        ShowToast($"{user.Name}'s application has been rejected.");
        CloseRejectModal();
        CloseModal();
        CalculateStatistics();
        StateHasChanged();
    }

