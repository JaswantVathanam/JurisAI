    // Appearance Preferences Methods
    private async Task LoadThemePreferences()
    {
        if (currentUser == null) return;

        try
        {
            var prefs = await JSRuntime.InvokeAsync<ThemePreference>("getThemePreference", currentUser.Id);
            if (prefs != null)
            {
                selectedTheme = prefs.Theme ?? "dark";
                highContrast = prefs.HighContrast;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // If loading fails, use defaults
            selectedTheme = "dark";
            highContrast = false;
        }
    }

    private async Task SetTheme(string theme)
    {
        if (currentUser == null) return;

        selectedTheme = theme;
        
        // Save and apply immediately
        await JSRuntime.InvokeVoidAsync("saveThemePreference", currentUser.Id, selectedTheme, highContrast);
        
        Console.WriteLine($"✓ Theme changed to: {theme}");
    }

    private async Task OnHighContrastChanged(ChangeEventArgs e)
    {
        if (currentUser == null) return;

        highContrast = (bool)(e.Value ?? false);
        
        // Save and apply immediately
        await JSRuntime.InvokeVoidAsync("saveThemePreference", currentUser.Id, selectedTheme, highContrast);
        
        Console.WriteLine($"✓ High contrast changed to: {highContrast}");
    }

    // Helper class for theme preferences
    private class ThemePreference
    {
        public string? Theme { get; set; }
        public bool HighContrast { get; set; }
    }

    public void Dispose()
    {
        successTimer?.Dispose();
        errorTimer?.Dispose();
        LangService.OnLanguageChanged -= OnLanguageChanged;
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }
